{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CopyPaste",
  "version": "0.1.0",
  "identifier": "com.copypaste.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "CopyPaste",
        "width": 380,
        "height": 520,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "center": false,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "tooltip": "CopyPaste"
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "signingIdentity": null,
      "providerShortName": null
    }
  }
}
