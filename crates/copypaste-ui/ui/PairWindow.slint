// PairWindow.slint — CopyPaste device pairing screen
// Shows own fingerprint, peer input, paired device list
//
// Slint 1.8 compatible. Tested with fluent-dark style.

import { Button, LineEdit, ScrollView } from "std-widgets.slint";

export struct PairedDeviceEntry {
    name: string,
    fingerprint: string,
    fingerprint-short: string,
}

component SectionTitle inherits Text {
    font-size: 10px;
    font-weight: 700;
    color: #6c7086;
}

export component PairWindow inherits Window {
    title: "CopyPaste — Pair Device";
    preferred-width: 520px;
    preferred-height: 580px;
    min-width: 400px;
    min-height: 480px;
    background: #1e1e2e;

    // ── Properties ────────────────────────────────────────────────────────────
    in-out property <string> own-fingerprint:             "";
    in-out property <[PairedDeviceEntry]> paired-devices: [];
    in-out property <string> status-message:  "";
    in-out property <bool>   status-is-error: false;

    private property <string> peer-input: "";
    private property <bool>   input-valid: false;

    // ── Callbacks ─────────────────────────────────────────────────────────────
    callback pair(string);
    callback remove-peer(string);
    callback close();

    // ── Layout ────────────────────────────────────────────────────────────────
    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Title bar
        Rectangle {
            height: 48px;
            background: #181825;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 12px;
                alignment: space-between;

                Text {
                    text: "Pair Device";
                    font-size: 17px;
                    font-weight: 700;
                    color: #cdd6f4;
                    vertical-alignment: center;
                }
            }
        }

        ScrollView {
            VerticalLayout {
                padding: 24px;
                spacing: 22px;

                // ── Own Fingerprint ────────────────────────────────────────
                VerticalLayout {
                    spacing: 10px;

                    SectionTitle { text: "YOUR DEVICE FINGERPRINT"; }

                    Rectangle {
                        border-radius: 10px;
                        background: #181825;
                        border-width: 1px;
                        border-color: #45475a;
                        padding: 20px;

                        VerticalLayout {
                            spacing: 16px;
                            alignment: center;

                            Text {
                                text: root.own-fingerprint == "" ? "Generating…" : root.own-fingerprint;
                                color: #89b4fa;
                                font-size: 17px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                overflow: elide;
                            }

                            Rectangle {
                                height: 120px;
                                border-radius: 8px;
                                background: #313244;
                                border-color: #45475a;
                                border-width: 1px;

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;
                                    padding: 16px;

                                    Text {
                                        text: "QR code will appear here";
                                        color: #6c7086;
                                        font-size: 13px;
                                        horizontal-alignment: center;
                                    }

                                    Text {
                                        text: "(coming soon)";
                                        color: #45475a;
                                        font-size: 11px;
                                        horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Pair New Device ────────────────────────────────────────
                VerticalLayout {
                    spacing: 10px;

                    SectionTitle { text: "PAIR NEW DEVICE"; }

                    VerticalLayout {
                        spacing: 8px;

                        peer-field := LineEdit {
                            placeholder-text: "Enter peer fingerprint (hex)";
                            text <=> root.peer-input;
                            edited(text) => {
                                root.peer-input = text;
                                // Valid when non-empty (Rust callback performs full validation)
                                root.input-valid = text != "";
                            }
                            accepted => {
                                if (root.input-valid) {
                                    root.pair(root.peer-input);
                                }
                            }
                        }

                        HorizontalLayout {
                            alignment: end;
                            Button {
                                text: "Pair";
                                primary: true;
                                enabled: root.input-valid;
                                clicked => { root.pair(root.peer-input); }
                            }
                        }
                    }

                    if root.status-message != "": Rectangle {
                        border-radius: 6px;
                        background: root.status-is-error ? #45242e : #1e3a2f;
                        border-color: root.status-is-error ? #f38ba8 : #a6e3a1;
                        border-width: 1px;
                        padding: 10px;
                        padding-left: 14px;
                        padding-right: 14px;

                        Text {
                            text: root.status-message;
                            color: root.status-is-error ? #f38ba8 : #a6e3a1;
                            font-size: 13px;
                            wrap: word-wrap;
                        }
                    }
                }

                // ── Paired Devices List ────────────────────────────────────
                VerticalLayout {
                    spacing: 10px;

                    SectionTitle { text: "PAIRED DEVICES"; }

                    if root.paired-devices.length == 0: Rectangle {
                        border-radius: 8px;
                        background: #181825;
                        border-color: #313244;
                        border-width: 1px;
                        padding: 16px;
                        height: 52px;

                        Text {
                            text: "No paired devices yet";
                            color: #585b70;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    for device in root.paired-devices: Rectangle {
                        border-radius: 8px;
                        background: #181825;
                        border-color: #313244;
                        border-width: 1px;

                        HorizontalLayout {
                            padding: 12px;
                            alignment: space-between;
                            spacing: 12px;

                            VerticalLayout {
                                spacing: 4px;

                                Text {
                                    text: device.name == "" ? "Unknown Device" : device.name;
                                    color: #cdd6f4;
                                    font-size: 14px;
                                    font-weight: 600;
                                    overflow: elide;
                                }

                                Text {
                                    text: device.fingerprint-short;
                                    color: #89b4fa;
                                    font-size: 12px;
                                    overflow: elide;
                                }
                            }

                            Button {
                                text: "Remove";
                                clicked => { root.remove-peer(device.fingerprint); }
                            }
                        }
                    }

                    Rectangle { height: 8px; }
                }
            }
        }

        // ── Footer ─────────────────────────────────────────────────────────
        Rectangle {
            height: 56px;
            background: #181825;
            border-color: #313244;
            border-width: 1px;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 20px;
                alignment: end;

                Button {
                    text: "Close";
                    clicked => { root.close(); }
                }
            }
        }
    }
}
