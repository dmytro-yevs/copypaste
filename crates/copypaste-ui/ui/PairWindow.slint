// PairWindow.slint — CopyPaste device pairing screen
// Shows own fingerprint, peer input, paired device list
//
// Slint 1.8 compatible. Tested with fluent-dark style.

import { Button, LineEdit, ScrollView } from "std-widgets.slint";

export struct PairedDeviceEntry {
    name: string,
    fingerprint: string,
    fingerprint-short: string,
}

component SectionTitle inherits Text {
    font-size: 10px;
    font-weight: 700;
    color: #6c7086;
}

export component PairWindow inherits Window {
    title: @tr("CopyPaste — Pair Device");
    preferred-width: 520px;
    preferred-height: 580px;
    min-width: 400px;
    min-height: 480px;
    background: #1e1e2e;

    // ── Properties ────────────────────────────────────────────────────────────
    in-out property <string> own-fingerprint:             "";
    in-out property <[PairedDeviceEntry]> paired-devices: [];
    in-out property <string> status-message:  "";
    in-out property <bool>   status-is-error: false;

    private property <string> peer-input: "";
    private property <string> password-input: "";
    private property <bool>   input-valid: false;
    private property <bool>   password-valid: false;

    // T4 (v0.3) — manual revoke confirmation dialog state. We keep the
    // fingerprint of the candidate peer in `revoke-target-fp` while the
    // dialog is open so the user sees what they're about to revoke and the
    // Rust side knows which peer to act on when they hit "Revoke".
    private property <bool>   revoke-confirm-open: false;
    private property <string> revoke-target-fp:    "";
    private property <string> revoke-target-name:  "";

    // ── Callbacks ─────────────────────────────────────────────────────────────
    callback pair(string);
    // Beta W3.2 — PAKE-based pairing using a shared password between two devices.
    // Emits (peer_fingerprint, password). Daemon validates both, then drives
    // the 3-message PAKE handshake. The UI does a basic min-length check up
    // front so the user gets immediate feedback before the round-trip.
    callback pair-with-password(string, string);
    callback remove-peer(string);
    // T4 (v0.3) — fired when the user confirms the revoke-confirmation
    // dialog. Distinct from `remove-peer` so the Rust side can route this
    // to the daemon's `revoke_peer` IPC (which writes an audit row) rather
    // than the legacy `unpair_peer`.
    callback revoke-peer(string);
    callback close();

    // ── Layout ────────────────────────────────────────────────────────────────
    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Title bar
        Rectangle {
            height: 48px;
            background: #181825;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 12px;
                alignment: space-between;

                Text {
                    text: @tr("Pair Device");
                    font-size: 17px;
                    font-weight: 700;
                    color: #cdd6f4;
                    vertical-alignment: center;
                }
            }
        }

        ScrollView {
            VerticalLayout {
                padding: 24px;
                spacing: 22px;

                // ── Own Fingerprint ────────────────────────────────────────
                VerticalLayout {
                    spacing: 10px;

                    SectionTitle { text: @tr("YOUR DEVICE FINGERPRINT"); }

                    Rectangle {
                        border-radius: 10px;
                        background: #181825;
                        border-width: 1px;
                        border-color: #45475a;
                        padding: 20px;

                        VerticalLayout {
                            spacing: 16px;
                            alignment: center;

                            Text {
                                text: root.own-fingerprint == "" ? @tr("Generating…") : root.own-fingerprint;
                                color: #89b4fa;
                                font-size: 17px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                overflow: elide;
                            }

                            Rectangle {
                                height: 120px;
                                border-radius: 8px;
                                background: #313244;
                                border-color: #45475a;
                                border-width: 1px;

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;
                                    padding: 16px;

                                    Text {
                                        text: @tr("QR code will appear here");
                                        color: #6c7086;
                                        font-size: 13px;
                                        horizontal-alignment: center;
                                    }

                                    Text {
                                        text: @tr("(coming soon)");
                                        color: #45475a;
                                        font-size: 11px;
                                        horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Pair New Device ────────────────────────────────────────
                VerticalLayout {
                    spacing: 10px;

                    SectionTitle { text: @tr("PAIR NEW DEVICE"); }

                    VerticalLayout {
                        spacing: 8px;

                        peer-field := LineEdit {
                            placeholder-text: @tr("Enter peer fingerprint (hex)");
                            text <=> root.peer-input;
                            edited(text) => {
                                root.peer-input = text;
                                // Valid when non-empty (Rust callback performs full validation)
                                root.input-valid = text != "";
                            }
                            accepted => {
                                if (root.input-valid) {
                                    root.pair(root.peer-input);
                                }
                            }
                        }

                        HorizontalLayout {
                            alignment: end;
                            Button {
                                text: @tr("Pair");
                                primary: true;
                                enabled: root.input-valid;
                                clicked => { root.pair(root.peer-input); }
                            }
                        }

                        // Beta W3.2 — password field for PAKE pairing.
                        password-field := LineEdit {
                            placeholder-text: @tr("Shared password (min 6 chars)");
                            input-type: password;
                            text <=> root.password-input;
                            edited(text) => {
                                root.password-input = text;
                                // UI guard mirrors the daemon-side check; both
                                // count Unicode scalars, not UTF-8 bytes.
                                // Slint 1.8 strings: no character-count expression — daemon
                                // re-validates on Unicode scalars (>=6). We just guard against
                                // an empty password here so the button stays disabled.
                                root.password-valid = text != "";
                            }
                            accepted => {
                                if (root.input-valid && root.password-valid) {
                                    root.pair-with-password(root.peer-input, root.password-input);
                                }
                            }
                        }

                        HorizontalLayout {
                            alignment: end;
                            Button {
                                text: @tr("Pair with Password");
                                primary: true;
                                enabled: root.input-valid && root.password-valid;
                                clicked => {
                                    root.pair-with-password(root.peer-input, root.password-input);
                                }
                            }
                        }
                    }

                    if root.status-message != "": Rectangle {
                        border-radius: 6px;
                        background: root.status-is-error ? #45242e : #1e3a2f;
                        border-color: root.status-is-error ? #f38ba8 : #a6e3a1;
                        border-width: 1px;
                        padding: 10px;
                        padding-left: 14px;
                        padding-right: 14px;

                        Text {
                            text: root.status-message;
                            color: root.status-is-error ? #f38ba8 : #a6e3a1;
                            font-size: 13px;
                            wrap: word-wrap;
                        }
                    }
                }

                // ── Paired Devices List ────────────────────────────────────
                VerticalLayout {
                    spacing: 10px;

                    SectionTitle { text: @tr("PAIRED DEVICES"); }

                    if root.paired-devices.length == 0: Rectangle {
                        border-radius: 8px;
                        background: #181825;
                        border-color: #313244;
                        border-width: 1px;
                        padding: 16px;
                        min-height: 96px;

                        VerticalLayout {
                            alignment: center;
                            spacing: 6px;
                            padding: 8px;

                            Text {
                                text: @tr("No peers discovered.");
                                color: #cdd6f4;
                                font-size: 13px;
                                font-weight: 600;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: @tr("Ensure other device is on same Wi-Fi and running CopyPaste.");
                                color: #6c7086;
                                font-size: 12px;
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }
                        }
                    }

                    for device in root.paired-devices: Rectangle {
                        border-radius: 8px;
                        background: #181825;
                        border-color: #313244;
                        border-width: 1px;

                        HorizontalLayout {
                            padding: 12px;
                            alignment: space-between;
                            spacing: 12px;

                            VerticalLayout {
                                spacing: 4px;

                                Text {
                                    text: device.name == "" ? @tr("Unknown Device") : device.name;
                                    color: #cdd6f4;
                                    font-size: 14px;
                                    font-weight: 600;
                                    overflow: elide;
                                }

                                Text {
                                    text: device.fingerprint-short;
                                    color: #89b4fa;
                                    font-size: 12px;
                                    overflow: elide;
                                }
                            }

                            // T4 (v0.3) — clicking "Revoke" no longer fires
                            // the daemon call directly; it opens the
                            // confirmation overlay below. Revocation is
                            // destructive (peer must re-pair to recover) so
                            // a typed confirmation dialog is mandatory.
                            Button {
                                text: @tr("Revoke");
                                clicked => {
                                    root.revoke-target-fp   = device.fingerprint;
                                    root.revoke-target-name = device.name;
                                    root.revoke-confirm-open = true;
                                }
                            }
                        }
                    }

                    Rectangle { height: 8px; }
                }
            }
        }

        // ── Footer ─────────────────────────────────────────────────────────
        Rectangle {
            height: 56px;
            background: #181825;
            border-color: #313244;
            border-width: 1px;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 20px;
                alignment: end;

                Button {
                    text: @tr("Close");
                    clicked => { root.close(); }
                }
            }
        }
    }

    // ── Revoke confirmation dialog (T4, v0.3) ──────────────────────────────
    //
    // Modal overlay shown when `revoke-confirm-open` is true. Sits on top
    // of the main VerticalLayout (Slint stacks siblings of Window in
    // declaration order, so this overlay paints last → renders on top).
    //
    // Two buttons:
    //   * Cancel — closes the dialog, leaves the peer paired.
    //   * Revoke — fires `revoke-peer(fingerprint)` and closes the dialog.
    //     The Rust side then routes the callback to the daemon's
    //     `revoke_peer` IPC, which both removes the peer from the local
    //     store and writes the audit row consumed by the v1.0 protocol.
    if root.revoke-confirm-open: Rectangle {
        width:  root.width;
        height: root.height;
        background: #000000aa;

        TouchArea {
            // Soaks up clicks on the backdrop so the underlying list
            // doesn't react while the dialog is open.
            width:  parent.width;
            height: parent.height;
        }

        Rectangle {
            x: (parent.width  - 380px) / 2;
            y: (parent.height - 200px) / 2;
            width:  380px;
            height: 200px;
            background: #1e1e2e;
            border-radius: 12px;
            border-width: 1px;
            border-color: #45475a;

            VerticalLayout {
                padding: 20px;
                spacing: 14px;

                Text {
                    text: @tr("Revoke this device?");
                    color: #cdd6f4;
                    font-size: 16px;
                    font-weight: 700;
                }

                Text {
                    text: root.revoke-target-name == ""
                        ? @tr("Unknown Device")
                        : root.revoke-target-name;
                    color: #89b4fa;
                    font-size: 13px;
                    overflow: elide;
                }

                Text {
                    text: @tr("This device will no longer sync. You'll need to pair again to restore it.");
                    color: #a6adc8;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    alignment: end;
                    spacing: 10px;

                    Button {
                        text: @tr("Cancel");
                        clicked => {
                            root.revoke-confirm-open = false;
                            root.revoke-target-fp    = "";
                            root.revoke-target-name  = "";
                        }
                    }

                    Button {
                        text: @tr("Revoke");
                        primary: true;
                        clicked => {
                            root.revoke-peer(root.revoke-target-fp);
                            root.revoke-confirm-open = false;
                            root.revoke-target-fp    = "";
                            root.revoke-target-name  = "";
                        }
                    }
                }
            }
        }
    }
}
