// pair.slint — Pair view for CopyPaste UI v0.4.
// T3.3: PairView component with Scan / Show / Code pill toggle.
// No IPC wiring yet — T3.4 imports this into AppWindow.
//
// Slint 1.8 compatible.

import { Theme } from "../theme.slint";
import { Icons } from "../icons.slint";
import { IconButton, PrimaryButton, SecondaryButton } from "../primitives.slint";
import { LineEdit } from "std-widgets.slint";

// ---------------------------------------------------------------------------
// PillTab — single pill toggle segment
// ---------------------------------------------------------------------------
component PillTab inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> active: false;
    callback activated();

    height: 30px;
    min-width: 80px;
    border-radius: Theme.radius-sm;
    background: root.active ? Theme.accent-solid : transparent;

    ta := TouchArea {
        mouse-cursor: MouseCursor.pointer;
        clicked => { root.activated(); }
    }

    HorizontalLayout {
        padding-left: Theme.space-3;
        padding-right: Theme.space-3;
        spacing: Theme.space-2;
        alignment: center;

        Image {
            source: root.icon;
            width: 13px;
            height: 13px;
            colorize: root.active ? Theme.text-inverse : (ta.has-hover ? Theme.text-primary : Theme.text-secondary);
        }

        Text {
            text: root.label;
            font-size: Theme.font-body;
            font-weight: root.active ? 600 : 400;
            color: root.active ? Theme.text-inverse : (ta.has-hover ? Theme.text-primary : Theme.text-secondary);
        }
    }

    animate background { duration: Theme.anim-row; easing: linear; }
}

// ---------------------------------------------------------------------------
// PairView — exported component
// pair-mode: 0 = Scan, 1 = Show QR, 2 = Code entry
// ---------------------------------------------------------------------------
export component PairView inherits Rectangle {
    // ── Properties ──────────────────────────────────────────────────────────
    in-out property <int> pair-mode: 1;   // 0=Scan, 1=Show, 2=Code
    in property <image> qr-image;
    in property <string> pair-code: "";
    in property <string> status-text: "Waiting for peer…";
    in property <bool> status-is-error: false;

    // ── Callbacks ────────────────────────────────────────────────────────────
    callback regenerate();
    callback pair-with-code(string);
    callback cancel();
    callback pair-succeeded(string);  // fingerprint

    // Private state
    private property <string> code-input: "";

    background: Theme.surface-base;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // ── Toolbar ─────────────────────────────────────────────────────────
        Rectangle {
            height: 48px;
            background: Theme.surface-sidebar;

            HorizontalLayout {
                padding-left: Theme.panel-inset;
                padding-right: Theme.panel-inset;
                spacing: Theme.space-4;
                alignment: space-between;

                Text {
                    text: "Pair a new device";
                    font-size: Theme.font-heading;
                    font-weight: 600;
                    color: Theme.text-primary;
                    vertical-alignment: center;
                }

                IconButton {
                    icon: Icons.x-close;
                    label: "Cancel";
                    style: "ghost";
                    clicked => { root.cancel(); }
                }
            }
        }

        // Hairline separator
        Rectangle {
            height: 1px;
            background: Theme.border-subtle;
        }

        // ── Pill toggle ──────────────────────────────────────────────────────
        Rectangle {
            height: 48px;
            background: Theme.surface-panel;

            HorizontalLayout {
                alignment: center;
                padding-top: Theme.space-2;
                padding-bottom: Theme.space-2;

                // Container for pills
                Rectangle {
                    height: 34px;
                    border-radius: Theme.radius-row;
                    background: Theme.surface-elevated;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    padding: 2px;

                    HorizontalLayout {
                        spacing: 2px;
                        padding: 2px;
                        alignment: center;

                        PillTab {
                            label: "Scan";
                            icon: Icons.scan-line;
                            active: root.pair-mode == 0;
                            activated => { root.pair-mode = 0; }
                        }

                        PillTab {
                            label: "Show";
                            icon: Icons.qr-code;
                            active: root.pair-mode == 1;
                            activated => { root.pair-mode = 1; }
                        }

                        PillTab {
                            label: "Code";
                            icon: Icons.key-round;
                            active: root.pair-mode == 2;
                            activated => { root.pair-mode = 2; }
                        }
                    }
                }
            }
        }

        // Hairline separator
        Rectangle {
            height: 1px;
            background: Theme.border-subtle;
        }

        // ── Mode content area ─────────────────────────────────────────────────
        Rectangle {
            vertical-stretch: 1;
            background: Theme.surface-base;
            clip: true;

            // ── SHOW mode (QR code) ──────────────────────────────────────────
            if root.pair-mode == 1: VerticalLayout {
                alignment: center;
                spacing: Theme.section-gap;
                padding: Theme.section-gap;

                // QR image area — wrapped in a centering row so the fixed-width
                // card sits in the horizontal middle of the pane.
                HorizontalLayout {
                    alignment: center;

                    Rectangle {
                        height: 200px;
                        width: 200px;
                        border-radius: Theme.radius-panel;
                        background: #FFFFFF;  // QR always on white
                        border-width: 2px;
                        border-color: Theme.border-regular;

                        HorizontalLayout {
                            alignment: center;

                            VerticalLayout {
                                alignment: center;

                                // Show QR image if available, else placeholder
                                if root.qr-image.width > 0: Image {
                                    source: root.qr-image;
                                    width: 180px;
                                    height: 180px;
                                    image-fit: contain;
                                }

                                if root.qr-image.width == 0: VerticalLayout {
                                    alignment: center;
                                    spacing: Theme.space-2;

                                    Image {
                                        source: Icons.qr-code;
                                        width: 64px;
                                        height: 64px;
                                        colorize: #888888;
                                        horizontal-alignment: center;
                                    }

                                    Text {
                                        text: "Generating QR…";
                                        font-size: Theme.font-caption;
                                        color: #888888;
                                        horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                // Pair code display
                if root.pair-code != "": VerticalLayout {
                    alignment: center;
                    spacing: Theme.space-2;

                    Text {
                        text: "Pair code";
                        font-size: Theme.font-caption;
                        color: Theme.text-secondary;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: root.pair-code;
                        font-size: 24px;
                        font-weight: 700;
                        color: Theme.accent-solid;
                        letter-spacing: 4px;
                        horizontal-alignment: center;
                    }
                }

                // Regenerate button
                HorizontalLayout {
                    alignment: center;

                    SecondaryButton {
                        icon: Icons.refresh;
                        label: "Regenerate";
                        clicked => { root.regenerate(); }
                    }
                }
            }

            // ── SCAN mode (camera placeholder) ───────────────────────────────
            if root.pair-mode == 0: VerticalLayout {
                alignment: center;
                spacing: Theme.space-4;
                padding: Theme.section-gap;

                // Camera viewport placeholder
                Rectangle {
                    height: 240px;
                    width: 240px;
                    border-radius: Theme.radius-panel;
                    background: Theme.surface-elevated;
                    border-width: 2px;
                    border-color: Theme.border-regular;

                    VerticalLayout {
                        alignment: center;
                        spacing: Theme.space-3;

                        Image {
                            source: Icons.scan-line;
                            width: 48px;
                            height: 48px;
                            colorize: Theme.text-tertiary;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "Camera coming in v0.4";
                            font-size: Theme.font-body;
                            color: Theme.text-tertiary;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "Use Show or Code mode to pair now.";
                            font-size: Theme.font-caption;
                            color: Theme.text-tertiary;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                    }
                }
            }

            // ── CODE entry mode ──────────────────────────────────────────────
            if root.pair-mode == 2: VerticalLayout {
                alignment: center;
                spacing: Theme.section-gap;
                padding: Theme.section-gap;

                VerticalLayout {
                    alignment: center;
                    spacing: Theme.space-3;

                    Text {
                        text: "Enter the 6-digit pair code";
                        font-size: Theme.font-heading;
                        color: Theme.text-primary;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "Ask the other device to display its code in Show mode.";
                        font-size: Theme.font-caption;
                        color: Theme.text-secondary;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }

                // Code input field
                HorizontalLayout {
                    alignment: center;

                    code-edit := LineEdit {
                        width: 200px;
                        placeholder-text: "00-00-00";
                        text <=> root.code-input;
                        font-size: 20px;
                        accepted => {
                            if (root.code-input != "") {
                                root.pair-with-code(root.code-input);
                            }
                        }
                    }
                }

                // Connect button
                HorizontalLayout {
                    alignment: center;

                    PrimaryButton {
                        icon: Icons.link-2;
                        label: "Connect";
                        enabled: root.code-input != "";
                        clicked => {
                            if (root.code-input != "") {
                                root.pair-with-code(root.code-input);
                            }
                        }
                    }
                }
            }
        }

        // ── Status bar ────────────────────────────────────────────────────────
        Rectangle {
            height: 36px;
            background: root.status-is-error ? Theme.color-danger.with-alpha(0.15) : Theme.surface-panel;
            border-width: 1px;
            border-color: root.status-is-error ? Theme.color-danger.with-alpha(0.4) : Theme.border-subtle;

            HorizontalLayout {
                padding-left: Theme.panel-inset;
                padding-right: Theme.panel-inset;
                spacing: Theme.space-2;
                alignment: start;

                if root.status-is-error: Image {
                    source: Icons.alert-triangle;
                    width: 14px;
                    height: 14px;
                    colorize: Theme.color-danger;
                    y: (parent.height - self.height) / 2;
                }

                if !root.status-is-error: Image {
                    source: Icons.check-circle-2;
                    width: 14px;
                    height: 14px;
                    colorize: Theme.text-tertiary;
                    y: (parent.height - self.height) / 2;
                }

                Text {
                    text: root.status-text;
                    font-size: Theme.font-caption;
                    color: root.status-is-error ? Theme.color-danger : Theme.text-secondary;
                    vertical-alignment: center;
                }
            }
        }
    }
}
