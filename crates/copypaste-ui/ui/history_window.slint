// HistoryWindow — CopyPaste clipboard history UI
// Displays paginated clipboard items from the daemon via IPC.
// User clicks an item to paste it back to the system clipboard.
// Settings button opens the app configuration panel.

import { ScrollView, Button, HorizontalBox, VerticalBox, ListView, LineEdit } from "std-widgets.slint";

struct HistoryItem {
    id: string,
    content-type: string,
    preview: string,
    timestamp: string,
    is-sensitive: bool,
    // Wave 3.4: optional thumbnail metadata for image items.
    // When the daemon ships an inline thumbnail (future IPC method
    // `get_image_thumbnail(id)` — see TODO in main.rs), `thumb-source`
    // is bound to a real `image`. Until then the row falls back to a
    // styled placeholder rectangle showing dimensions in `preview`.
    thumb-source: image,
    thumb-width: int,
    thumb-height: int,
}

export component HistoryWindow inherits Window {
    title: @tr("CopyPaste History");
    width: 480px;
    height: 600px;
    background: #1e1e2e;

    // Bindable state — updated from Rust
    in property <[HistoryItem]> items;
    in property <string> status-text: @tr("Ready");
    in property <bool> loading: false;
    in property <int> total-count: 0;

    // beta-bonus (slint-search): live search query. Two-way bound to the
    // search LineEdit; Rust reads it via `get_search_query()` when the
    // debounced `search-changed(string)` callback fires (200 ms after the
    // last keystroke). Filtering itself is done locally on `items` so a
    // single IPC call backs many keystrokes — no IPC concurrency issues.
    in-out property <string> search-query: "";

    // Callbacks fired to Rust
    callback item-clicked(string);   // id of clicked item
    callback refresh-requested();
    callback load-next-page();
    callback load-prev-page();
    callback settings-requested();  // open settings panel
    // beta-bonus (slint-search): fired 200 ms after the user stops typing
    // in the search field. The Rust handler re-filters the cached page
    // (see `AppState::last_page_items`) and swaps the visible model.
    callback search-changed(string);

    // beta-bonus (slint-search): 200 ms debounce timer. Restarts on every
    // keystroke (`edited` handler in `search-input` below) and only fires
    // `search-changed` once the user pauses — matches the spec's debounce
    // requirement while keeping the per-keystroke handler cheap.
    debounce-timer := Timer {
        interval: 200ms;
        running: false;
        triggered => {
            self.running = false;
            search-changed(root.search-query);
        }
    }

    // beta-bonus (slint-search): filtering itself is performed Rust-side
    // (`filter_history_items` in `windows.rs`) because Slint 1.8 strings
    // lack `to-lower-case` / `contains` expressions. The Rust handler
    // swaps the `items` model when `search-changed` fires, so the
    // ListView below always renders an already-filtered slice.

    VerticalBox {
        padding: 8px;
        spacing: 6px;

        // Header bar
        HorizontalBox {
            spacing: 8px;
            height: 36px;

            Text {
                text: @tr("Clipboard History");
                font-size: 16px;
                color: #cdd6f4;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Button {
                text: @tr("Refresh");
                enabled: !loading;
                clicked => { refresh-requested(); }
            }

            Button {
                // Gear glyph prefixed before the localised "Settings" label so
                // the icon stays put while the word flips with the locale.
                text: "⚙ " + @tr("Settings");
                clicked => { settings-requested(); }
            }
        }

        // beta-bonus (slint-search): search input. `edited` fires on every
        // keystroke and (re)starts the 200 ms debounce timer; the Rust
        // handler then re-filters `items` once the user pauses.
        search-input := LineEdit {
            placeholder-text: "Search history...";
            text <=> root.search-query;
            height: 28px;
            edited(text) => {
                debounce-timer.running = false;
                debounce-timer.running = true;
            }
        }

        // Status line
        Text {
            text: status-text;
            font-size: 11px;
            color: #a6adc8;
            height: 18px;
        }

        // Item list
        Rectangle {
            border-radius: 6px;
            background: #181825;
            vertical-stretch: 1;

            if loading : Rectangle {
                background: #181825;
                Text {
                    text: @tr("Loading…");
                    color: #a6adc8;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            if !loading && items.length == 0 : Rectangle {
                background: transparent;
                Text {
                    text: @tr("No clipboard items.\nCopy something to get started.");
                    color: #6c7086;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    wrap: word-wrap;
                }
            }

            if !loading && items.length > 0 : ListView {
                for item[idx] in items : Rectangle {
                    height: 62px;
                    border-radius: 4px;
                    background: touch.has-hover ? #313244 : transparent;

                    touch := TouchArea {
                        clicked => { item-clicked(item.id); }
                    }

                    HorizontalBox {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 8px;

                        // Wave 3.4: image row leads with a thumbnail (or placeholder).
                        // Non-image rows keep the original 48×22 type badge.
                        if item.content-type == "image" : Rectangle {
                            width: 56px;
                            height: 42px;
                            border-radius: 4px;
                            background: #45475a;
                            clip: true;

                            // Real thumbnail when daemon ships pixels; falls back to
                            // an "IMG" tag until `get_image_thumbnail(id)` lands.
                            if item.thumb-width > 0 : Image {
                                source: item.thumb-source;
                                width: parent.width;
                                height: parent.height;
                                image-fit: contain;
                            }
                            if item.thumb-width == 0 : Text {
                                text: @tr("IMG");
                                color: #fab387;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        if item.content-type != "image" : Rectangle {
                            width: 48px;
                            height: 22px;
                            border-radius: 4px;
                            background: #313244;

                            Text {
                                text: item.content-type;
                                color: #89b4fa;
                                font-size: 10px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Content preview + timestamp
                        VerticalBox {
                            spacing: 2px;
                            horizontal-stretch: 1;
                            padding: 0;

                            Text {
                                text: item.is-sensitive ? "••••••••" : item.preview;
                                color: item.is-sensitive ? #f38ba8 : #cdd6f4;
                                font-size: 13px;
                                overflow: elide;
                            }

                            Text {
                                text: item.timestamp;
                                font-size: 10px;
                                color: #585b70;
                            }
                        }

                        // Sensitive badge
                        if item.is-sensitive : Rectangle {
                            width: 24px;
                            height: 24px;
                            border-radius: 12px;
                            background: #f38ba8;
                            Text {
                                text: "!";
                                color: #1e1e2e;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // Pagination footer
        HorizontalBox {
            spacing: 8px;
            height: 32px;

            Button {
                // i18n: mirror of "Next →" — single composite msgid covers
                // both arrow + label so translators can flip glyph placement
                // for RTL locales if needed.
                text: @tr("← Prev");
                clicked => { load-prev-page(); }
            }

            Text {
                // i18n: Slint 1.8 `@tr` plural form — singular | plural % count.
                // Use {n} in both forms to interpolate the count expression.
                // gettext picks msgstr[0..N-1] per the .po Plural-Forms header
                // (en: 2 forms, uk: 3 forms).
                text: total-count > 0
                    ? @tr("{n} item total" | "{n} items total" % total-count)
                    : "";
                color: #6c7086;
                font-size: 11px;
                horizontal-alignment: center;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Button {
                text: @tr("Next →");
                clicked => { load-next-page(); }
            }
        }
    }
}
