// bottom_tab_bar.slint — Android-style bottom navigation bar for CopyPaste v0.4.
// T5.3: shown on screens < 600dp (small Android). Hidden on ≥ 600dp (tablet / desktop).
//
// Tab indices: 0 = History  1 = Devices  2 = Pair  3 = Settings

import { Theme } from "../theme.slint";
import { Icons } from "../icons.slint";

// Single tab button inside the bottom bar.
component BottomTabItem inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> active: false;

    callback activated();

    background: transparent;
    horizontal-stretch: 1;

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.activated(); }
    }

    VerticalLayout {
        alignment: center;
        spacing: 3px;
        padding-top: 8px;
        padding-bottom: 8px;

        // Icon
        Image {
            source: root.icon;
            width: 20px;
            height: 20px;
            colorize: root.active ? Theme.accent-solid : Theme.text-secondary;
            horizontal-alignment: center;
        }

        // Active indicator — 2px accent gradient underline below icon
        if root.active: HorizontalLayout {
            alignment: center;
            Rectangle {
                height: 2px;
                width: 20px;
                background: Theme.accent-gradient;
                border-radius: 1px;
            }
        }

        // Label
        Text {
            text: root.label;
            font-size: Theme.font-caption;
            color: root.active ? Theme.accent-solid : Theme.text-secondary;
            horizontal-alignment: center;
            overflow: elide;
        }
    }
}

// ---------------------------------------------------------------------------
// BottomTabBar — exported component used in MainWindow when screen-width < 600px.
// ---------------------------------------------------------------------------
export component BottomTabBar inherits Rectangle {
    in-out property <int> active-tab: 0;

    callback tab-changed(int);

    height: 56px;
    background: Theme.surface-sidebar;

    // Top hairline separator
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: 1px;
        background: Theme.border-subtle;
    }

    HorizontalLayout {
        spacing: 0px;
        y: 1px;
        height: parent.height - 1px;

        BottomTabItem {
            icon: Icons.history;
            label: "History";
            active: root.active-tab == 0;
            activated => {
                root.active-tab = 0;
                root.tab-changed(0);
            }
        }

        BottomTabItem {
            icon: Icons.monitor-smartphone;
            label: "Devices";
            active: root.active-tab == 1;
            activated => {
                root.active-tab = 1;
                root.tab-changed(1);
            }
        }

        BottomTabItem {
            icon: Icons.link-2;
            label: "Pair";
            active: root.active-tab == 2;
            activated => {
                root.active-tab = 2;
                root.tab-changed(2);
            }
        }

        BottomTabItem {
            icon: Icons.settings-2;
            label: "Settings";
            active: root.active-tab == 3;
            activated => {
                root.active-tab = 3;
                root.tab-changed(3);
            }
        }
    }
}
