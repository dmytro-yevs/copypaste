// command_palette.slint — ⌘K overlay for CopyPaste v0.4 UI redesign.
// T5.1: full-screen scrim + centered 560px modal with search input + action list.
//
// Usage: set `open` to true to show the palette. The component covers the
// entire window (width/height 100%) and renders above everything (z: 100 in
// the parent). Visibility is driven by the `open` property so Slint can
// skip painting when hidden.

import { Theme } from "../theme.slint";

// ---------------------------------------------------------------------------
// PaletteAction — a single command entry displayed in the palette list.
// ---------------------------------------------------------------------------
export struct PaletteAction {
    id: string,
    label: string,
    shortcut: string,
}

// ---------------------------------------------------------------------------
// CommandPalette — full-screen scrim overlay with a centered command modal.
//
// Properties:
//   open           — show/hide the palette (two-way bindable)
//   actions        — list of PaletteAction entries to display
//   query          — current search/filter text (two-way bindable)
//   selected-index — keyboard-focused row (two-way bindable)
//
// Callbacks:
//   action-selected(id) — fired when the user activates an action
//   closed()            — fired when the user dismisses via scrim click or Esc
// ---------------------------------------------------------------------------
export component CommandPalette inherits Rectangle {
    in-out property <bool> open: false;
    in property <[PaletteAction]> actions: [];
    in-out property <string> query: "";
    in-out property <int> selected-index: 0;

    callback action-selected(string);
    callback closed();

    // Stretch to fill the entire parent (parent must be the window root).
    width: 100%;
    height: 100%;

    // Scrim: semi-transparent black when open, transparent otherwise.
    background: root.open ? Theme.overlay-scrim : transparent;
    visible: root.open;

    // ── Modal box ────────────────────────────────────────────────────────────
    Rectangle {
        width: 560px;
        // Height: search row (56px) + divider (1px) + up to 8 rows (44px each)
        // + bottom padding (8px). Clamped to avoid exceeding parent.
        height: 56px + 1px + (actions.length > 8 ? 8 * 44px : actions.length * 44px) + 8px;

        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 3;

        background: Theme.surface-elevated;
        border-radius: Theme.radius-overlay;
        drop-shadow-blur: 24px;
        drop-shadow-color: #00000066;
        drop-shadow-offset-y: 8px;
        clip: true;

        VerticalLayout {
            spacing: 0px;

            // ── Search input row ─────────────────────────────────────────────
            Rectangle {
                height: 56px;
                background: transparent;

                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    padding-top: 0px;
                    padding-bottom: 0px;
                    spacing: 10px;
                    alignment: center;

                    // Magnifier icon (Unicode fallback — no SVG dependency)
                    Text {
                        text: "⌘";
                        font-size: 16px;
                        color: Theme.text-secondary;
                        vertical-alignment: center;
                    }

                    TextInput {
                        text <=> root.query;
                        font-size: 15px;
                        color: Theme.text-primary;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                        // Clear query on close so next open starts fresh.
                    }

                    // Esc hint
                    Text {
                        text: "esc";
                        font-size: 11px;
                        color: Theme.text-secondary;
                        vertical-alignment: center;
                    }
                }
            }

            // ── Divider ───────────────────────────────────────────────────────
            Rectangle {
                height: 1px;
                background: Theme.border-subtle;
            }

            // ── Action rows ───────────────────────────────────────────────────
            for action[i] in root.actions: Rectangle {
                height: 44px;

                // Hover highlight — selected takes priority
                touch := TouchArea {}

                background: i == root.selected-index
                    ? Theme.row-selected
                    : (touch.has-hover ? Theme.row-hover : transparent);

                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    spacing: 8px;
                    alignment: center;

                    Text {
                        text: action.label;
                        font-size: 13px;
                        color: Theme.text-primary;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }

                    Text {
                        text: action.shortcut;
                        font-size: 11px;
                        color: Theme.text-secondary;
                        vertical-alignment: center;
                    }
                }

                // Activate on click
                TouchArea {
                    clicked => {
                        root.action-selected(action.id);
                        root.query = "";
                        root.selected-index = 0;
                        root.open = false;
                    }
                }
            }

            // ── Bottom padding ────────────────────────────────────────────────
            Rectangle {
                height: 8px;
                background: transparent;
            }
        }
    }

    // ── Scrim dismiss area (behind the modal, z: -1) ──────────────────────────
    TouchArea {
        z: -1;
        width: 100%;
        height: 100%;
        clicked => {
            root.closed();
            root.open = false;
            root.query = "";
            root.selected-index = 0;
        }
    }
}
