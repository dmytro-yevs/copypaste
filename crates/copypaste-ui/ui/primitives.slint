// primitives.slint — Reusable primitive components for CopyPaste UI v0.4.
// All colors via Theme tokens. No hardcoded values.
// Depends on T1.1 (theme.slint) and T1.2 (icons.slint).

import { Theme } from "theme.slint";
import { Icons } from "icons.slint";

// ---------------------------------------------------------------------------
// IconButton — icon + optional label, three style variants
// Every button in the app MUST use this or one of the typed variants below.
// ---------------------------------------------------------------------------
export component IconButton inherits Rectangle {
    in property <image> icon;
    in property <string> label: "";
    // style: "ghost" | "primary" | "secondary" | "danger"
    in property <string> style: "ghost";
    in property <bool> enabled: true;
    callback clicked();

    height: 28px;
    border-radius: 4px;
    opacity: root.enabled ? 1.0 : 0.4;

    background:
        !root.enabled ? transparent :
        root.style == "primary" ? Theme.accent-gradient :
        root.style == "secondary" ? Theme.surface-elevated :
        root.style == "danger" ? Theme.danger :
        ta.has-hover ? Theme.row-hover : transparent;

    border-width: root.style == "secondary" ? 1px : 0px;
    border-color: Theme.border-regular;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        padding-top: 4px;
        padding-bottom: 4px;
        spacing: 6px;
        alignment: center;

        Image {
            source: root.icon;
            width: 14px;
            height: 14px;
            colorize:
                root.style == "primary" ? Theme.text-inverse :
                root.style == "danger" ? Theme.danger :
                ta.has-hover ? Theme.text-primary : Theme.text-secondary;
        }

        if root.label != "": Text {
            text: root.label;
            font-size: 13px;
            color:
                root.style == "primary" ? Theme.text-inverse :
                root.style == "danger" ? Theme.danger :
                Theme.text-primary;
        }
    }

    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? MouseCursor.pointer : MouseCursor.default;
        clicked => { root.clicked(); }
    }

    animate background { duration: 80ms; easing: linear; }
}

// ---------------------------------------------------------------------------
// PrimaryButton — accent-gradient CTA, always has icon (spec rule)
// ---------------------------------------------------------------------------
export component PrimaryButton inherits IconButton {
    style: "primary";
}

// ---------------------------------------------------------------------------
// SecondaryButton — bordered surface, always has icon
// ---------------------------------------------------------------------------
export component SecondaryButton inherits IconButton {
    style: "secondary";
}

// ---------------------------------------------------------------------------
// GhostButton — no fill, hover only, always has icon
// ---------------------------------------------------------------------------
export component GhostButton inherits IconButton {
    style: "ghost";
}

// ---------------------------------------------------------------------------
// DangerButton — danger-colored text/icon, triggers ConfirmDialog externally
// ---------------------------------------------------------------------------
export component DangerButton inherits IconButton {
    style: "danger";
}

// ---------------------------------------------------------------------------
// SidebarTab — vertical sidebar navigation item (icon + label, active state)
// ---------------------------------------------------------------------------
export component SidebarTab inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> active: false;
    in property <bool> collapsed: false;  // sidebar collapsed → hide label
    callback activated();

    height: 32px;
    border-radius: 6px;
    background: root.active ? Theme.row-selected : (ta.has-hover ? Theme.row-hover : transparent);

    // 3px accent left-edge bar when active
    Rectangle {
        x: 0;
        y: 4px;
        width: root.active ? 3px : 0px;
        height: parent.height - 8px;
        border-radius: 1.5px;
        background: Theme.accent-gradient;
        animate width { duration: 80ms; easing: linear; }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 8px;
        spacing: 8px;
        alignment: center;

        Image {
            source: root.icon;
            width: 16px;
            height: 16px;
            colorize: root.active ? Theme.text-primary : (ta.has-hover ? Theme.text-primary : Theme.text-secondary);
        }

        if !root.collapsed: Text {
            text: root.label;
            font-size: 13px;
            color: root.active ? Theme.text-primary : Theme.text-secondary;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        mouse-cursor: MouseCursor.pointer;
        clicked => { root.activated(); }
    }

    animate background { duration: 80ms; easing: linear; }
}

// ---------------------------------------------------------------------------
// SubTabPill — horizontal pill selector (Simple / Advanced settings sub-tabs)
// ---------------------------------------------------------------------------
export component SubTabPill inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> active: false;
    callback activated();

    height: 28px;
    min-width: 80px;
    border-radius: 6px;
    background: root.active ? Theme.surface-elevated : transparent;
    border-width: root.active ? 1px : 0px;
    border-color: Theme.border-subtle;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        alignment: center;

        Image {
            source: root.icon;
            width: 13px;
            height: 13px;
            colorize: root.active ? Theme.text-primary : Theme.text-secondary;
        }

        Text {
            text: root.label;
            font-size: 12px;
            color: root.active ? Theme.text-primary : Theme.text-secondary;
        }
    }

    ta := TouchArea {
        mouse-cursor: MouseCursor.pointer;
        clicked => { root.activated(); }
    }

    animate background { duration: 80ms; easing: linear; }
}

// ---------------------------------------------------------------------------
// Card — panel container with title header, PhpStorm look
// ---------------------------------------------------------------------------
export component Card inherits Rectangle {
    in property <string> title: "";
    in property <image> title-icon;
    in property <bool> show-title-icon: false;
    @children

    border-radius: 8px;
    background: Theme.surface-panel;
    border-width: 1px;
    border-color: Theme.border-subtle;

    VerticalLayout {
        spacing: 0px;

        if root.title != "": Rectangle {
            height: 36px;
            border-radius: 8px;
            // Only round top corners — achieved via clipping the parent
            background: Theme.surface-sidebar;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;
                alignment: center;

                if root.show-title-icon: Image {
                    source: root.title-icon;
                    width: 14px;
                    height: 14px;
                    colorize: Theme.text-secondary;
                }

                Text {
                    text: root.title;
                    font-size: 12px;
                    font-weight: 600;
                    color: Theme.text-secondary;
                    letter-spacing: 0.4px;
                }

                Rectangle { horizontal-stretch: 1; }
            }
        }

        @children
    }
}

// ---------------------------------------------------------------------------
// SearchField — single-line text input with search icon prefix
// ---------------------------------------------------------------------------
export component SearchField inherits Rectangle {
    in-out property <string> text: "";
    in property <string> placeholder: "Search…";
    in property <bool> enabled: true;
    callback edited(string);

    height: 28px;
    border-radius: 6px;
    background: Theme.surface-elevated;
    border-width: 1px;
    border-color: fi.has-focus ? Theme.border-focus : Theme.border-subtle;
    clip: true;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        alignment: center;

        Image {
            source: Icons.search;
            width: 13px;
            height: 13px;
            colorize: Theme.text-tertiary;
        }

        fi := TextInput {
            text <=> root.text;
            font-size: 13px;
            color: Theme.text-primary;
            selection-background-color: Theme.row-selected;
            selection-foreground-color: Theme.text-primary;
            placeholder-color: Theme.text-tertiary;
            single-line: true;
            enabled: root.enabled;
            edited => { root.text = self.text; root.edited(self.text); }
        }

        if root.text != "": TouchArea {
            width: 16px;
            height: 16px;
            mouse-cursor: MouseCursor.pointer;
            clicked => { root.text = ""; fi.text = ""; root.edited(""); }

            Image {
                source: Icons.x-circle;
                width: 13px;
                height: 13px;
                colorize: Theme.text-tertiary;
            }
        }
    }

    animate border-color { duration: 80ms; easing: linear; }
}

// ---------------------------------------------------------------------------
// EmptyState — full-area placeholder for empty list/view states
// ---------------------------------------------------------------------------
export component EmptyState inherits Rectangle {
    in property <string> title;
    in property <string> body: "";
    in property <image> icon;
    // Optional CTA button
    in property <string> cta-label: "";
    in property <image> cta-icon;
    callback cta-clicked();

    background: transparent;

    VerticalLayout {
        alignment: center;
        spacing: 16px;
        padding: 32px;

        Image {
            source: root.icon;
            width: 48px;
            height: 48px;
            colorize: Theme.text-tertiary;
            horizontal-alignment: center;
        }

        Text {
            text: root.title;
            font-size: 16px;
            font-weight: 600;
            color: Theme.text-secondary;
            horizontal-alignment: center;
        }

        if root.body != "": Text {
            text: root.body;
            font-size: 13px;
            color: Theme.text-tertiary;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        if root.cta-label != "": HorizontalLayout {
            alignment: center;

            PrimaryButton {
                icon: root.cta-icon;
                label: root.cta-label;
                clicked => { root.cta-clicked(); }
            }
        }
    }
}

// ---------------------------------------------------------------------------
// ToggleRow — label (+ optional sub-label) + right-aligned toggle switch
// ---------------------------------------------------------------------------
export component ToggleRow inherits Rectangle {
    in property <string> label;
    in property <string> sub-label: "";
    in-out property <bool> checked: false;
    in property <bool> enabled: true;
    callback toggled(bool);

    height: 36px;
    background: transparent;
    opacity: root.enabled ? 1.0 : 0.4;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        alignment: center;

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 2px;

            Text {
                text: root.label;
                font-size: 13px;
                color: Theme.text-primary;
            }

            if root.sub-label != "": Text {
                text: root.sub-label;
                font-size: 11px;
                color: Theme.text-tertiary;
            }
        }

        // Toggle switch widget
        toggle-area := TouchArea {
            width: 36px;
            height: 20px;
            enabled: root.enabled;
            mouse-cursor: root.enabled ? MouseCursor.pointer : MouseCursor.default;
            clicked => {
                root.checked = !root.checked;
                root.toggled(root.checked);
            }

            Rectangle {
                width: 36px;
                height: 20px;
                border-radius: 10px;
                background: root.checked ? Theme.accent-solid : Theme.border-regular;
                animate background { duration: 120ms; easing: ease-in-out; }

                Rectangle {
                    x: root.checked ? parent.width - self.width - 2px : 2px;
                    y: 2px;
                    width: 16px;
                    height: 16px;
                    border-radius: 8px;
                    background: Theme.text-primary;
                    animate x { duration: 120ms; easing: ease-in-out; }
                }
            }
        }
    }
}

// ---------------------------------------------------------------------------
// Toast — transient bottom-right notification, auto-dismisses after 3s
// ---------------------------------------------------------------------------
export enum ToastKind { success, error, info }

export component Toast inherits Rectangle {
    in property <string> message: "";
    in property <ToastKind> kind: ToastKind.info;
    in-out property <bool> visible: false;
    callback dismissed();

    // Position anchoring is done by the parent (overlay layer in RootWindow)
    width: 280px;
    height: 44px;
    border-radius: 8px;
    border-width: 1px;
    background: Theme.surface-elevated;
    border-color:
        root.kind == ToastKind.success ? Theme.success :
        root.kind == ToastKind.error ? Theme.danger :
        Theme.border-regular;

    opacity: root.visible ? 1.0 : 0.0;
    animate opacity { duration: 160ms; easing: ease-out; }

    // Auto-dismiss timer
    timer := Timer {
        interval: 3000ms;
        running: root.visible;
        triggered => {
            root.visible = false;
            root.dismissed();
        }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        alignment: center;

        Image {
            source:
                root.kind == ToastKind.success ? Icons.check-circle :
                root.kind == ToastKind.error ? Icons.alert-triangle :
                Icons.info;
            width: 14px;
            height: 14px;
            colorize:
                root.kind == ToastKind.success ? Theme.success :
                root.kind == ToastKind.error ? Theme.danger :
                Theme.text-secondary;
        }

        Text {
            text: root.message;
            font-size: 13px;
            color: Theme.text-primary;
            horizontal-stretch: 1;
            overflow: elide;
        }

        TouchArea {
            width: 20px;
            height: 20px;
            mouse-cursor: MouseCursor.pointer;
            clicked => {
                root.visible = false;
                root.dismissed();
            }

            Image {
                source: Icons.x;
                width: 12px;
                height: 12px;
                colorize: Theme.text-tertiary;
            }
        }
    }
}

// ---------------------------------------------------------------------------
// ConfirmDialog — centered modal overlay with scrim
// ---------------------------------------------------------------------------
export component ConfirmDialog inherits Rectangle {
    in property <string> title: "Are you sure?";
    in property <string> body: "";
    in property <string> confirm-label: "Confirm";
    in property <string> cancel-label: "Cancel";
    in property <bool> danger: false;
    in-out property <bool> visible: false;
    callback confirmed();
    callback cancelled();

    // Full-window scrim — parent must stretch this to cover the window
    width: 100%;
    height: 100%;
    background: #00000099;  // overlay.scrim: #000000 @ 60%
    opacity: root.visible ? 1.0 : 0.0;
    visible: root.visible || self.opacity > 0.0;

    animate opacity { duration: 160ms; easing: ease-out; }

    // Dismiss on scrim click
    TouchArea {
        clicked => { root.visible = false; root.cancelled(); }
    }

    // Dialog panel (centered)
    dialog := Rectangle {
        width: 360px;
        height: dialog-layout.preferred-height + 48px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        border-radius: 12px;
        background: Theme.surface-elevated;
        border-width: 1px;
        border-color: Theme.border-regular;

        // Absorb clicks so scrim TouchArea doesn't trigger
        TouchArea {}

        dialog-layout := VerticalLayout {
            x: 24px;
            y: 24px;
            width: parent.width - 48px;
            spacing: 12px;

            Text {
                text: root.title;
                font-size: 15px;
                font-weight: 700;
                color: Theme.text-primary;
                wrap: word-wrap;
            }

            if root.body != "": Text {
                text: root.body;
                font-size: 13px;
                color: Theme.text-secondary;
                wrap: word-wrap;
            }

            HorizontalLayout {
                spacing: 8px;
                alignment: end;

                GhostButton {
                    icon: Icons.x;
                    label: root.cancel-label;
                    clicked => { root.visible = false; root.cancelled(); }
                }

                IconButton {
                    icon: root.danger ? Icons.alert-triangle : Icons.check-circle;
                    label: root.confirm-label;
                    style: root.danger ? "danger" : "primary";
                    clicked => { root.visible = false; root.confirmed(); }
                }
            }
        }
    }
}
