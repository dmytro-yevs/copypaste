// MainWindow.slint — Single-window shell for CopyPaste v0.4 UI redesign.
// T2.1: root window with collapsible sidebar + tab content area.
// T3.4: placeholder Rectangles replaced with real view components.
// T4.2: ItemDetailPanel component + MainWindow detail-* properties/callbacks.
// T5.2: FocusScope keyboard handler (⌘1-4, ⌘\, ⌘K, ⌘F, ⌘P, ⌘N, ⌘,, ⌘W,
//        ↑/↓ selection, ↵ copy, ⌫ delete, Esc layered dismiss).
//
// Tab indices:  0 = History  1 = Devices  2 = Pair  3 = Settings

import { Theme } from "theme.slint";
import { Icons } from "icons.slint";
import { SidebarTab, SearchField, GhostButton, PrimaryButton, DangerButton, SecondaryButton } from "primitives.slint";
import { HistoryView, ClipItem } from "views/history.slint";
import { DevicesView, DeviceEntry } from "views/devices.slint";
import { PairView } from "views/pair.slint";
import { SettingsView } from "views/settings.slint";
import { CommandPalette, PaletteAction } from "components/command_palette.slint";
import { BottomTabBar } from "components/bottom_tab_bar.slint";

// ---------------------------------------------------------------------------
// ItemDetailPanel — 320px right-side panel showing full detail of a selected
// clipboard item.  Visible only on the History tab (current-view == 0).
//
// Properties:
//   item           — the ClipItem to display (set by RootWindowHandle)
//   detail-visible — drives panel width (320px / 0px), animated
// Callbacks:
//   copy(), pin(), delete() — forwarded to RootWindowHandle for IPC dispatch
// ---------------------------------------------------------------------------
component ItemDetailPanel inherits Rectangle {
    in property <ClipItem> item;
    in property <bool> detail-visible: false;

    callback copy();
    callback pin();
    callback delete();

    width: root.detail-visible ? 320px : 0px;
    clip: true;
    background: Theme.surface-panel;

    animate width { duration: Theme.anim-panel; easing: ease-out; }

    // Left hairline border separating panel from view area
    Rectangle {
        x: 0;
        y: 0;
        width: 1px;
        height: parent.height;
        background: Theme.border-subtle;
    }

    // Main content — only rendered when panel is open to avoid layout work
    if root.detail-visible: VerticalLayout {
        x: 1px; // clear the hairline border
        width: parent.width - 1px;
        height: parent.height;
        spacing: 0px;
        padding-left: 16px;
        padding-right: 16px;
        padding-top: 16px;
        padding-bottom: 16px;

        // ── Kind badge + title row ─────────────────────────────────────────
        HorizontalLayout {
            spacing: 8px;
            alignment: start;

            // Kind badge chip
            Rectangle {
                height: 20px;
                width: kind-label.preferred-width + 12px;
                border-radius: 4px;
                background: Theme.surface-elevated;
                border-width: 1px;
                border-color: Theme.border-regular;

                kind-label := Text {
                    x: 6px;
                    text: root.item.kind;
                    font-size: 11px;
                    color: Theme.text-secondary;
                    vertical-alignment: center;
                }
            }

            // Pin indicator
            if root.item.pinned: Rectangle {
                height: 20px;
                width: pin-label.preferred-width + 12px;
                border-radius: 4px;
                background: Theme.surface-elevated;
                border-width: 1px;
                border-color: Theme.border-regular;

                pin-label := Text {
                    x: 6px;
                    text: "pinned";
                    font-size: 11px;
                    color: Theme.accent-solid;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle { height: 12px; background: transparent; }

        // ── Full content preview ───────────────────────────────────────────
        Rectangle {
            vertical-stretch: 1;
            background: Theme.surface-elevated;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.border-regular;
            clip: true;

            Flickable {
                width: parent.width;
                height: parent.height;
                viewport-height: preview-text.preferred-height + 16px;

                preview-text := Text {
                    x: 8px;
                    y: 8px;
                    width: parent.width - 16px;
                    text: root.item.redacted ? "[ sensitive — content hidden ]" : root.item.preview;
                    font-size: 13px;
                    color: root.item.redacted ? Theme.text-tertiary : Theme.text-primary;
                    wrap: word-wrap;
                }
            }
        }

        Rectangle { height: 12px; background: transparent; }

        // ── Metadata rows ──────────────────────────────────────────────────
        HorizontalLayout {
            spacing: 6px;
            alignment: start;

            Text {
                text: "Time:";
                font-size: 12px;
                color: Theme.text-tertiary;
                vertical-alignment: center;
            }

            Text {
                text: root.item.wall-time;
                font-size: 12px;
                color: Theme.text-secondary;
                vertical-alignment: center;
            }
        }

        Rectangle { height: 4px; background: transparent; }

        if root.item.source-device != "": HorizontalLayout {
            spacing: 6px;
            alignment: start;

            Text {
                text: "Device:";
                font-size: 12px;
                color: Theme.text-tertiary;
                vertical-alignment: center;
            }

            Text {
                text: root.item.source-device;
                font-size: 12px;
                color: Theme.text-secondary;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Rectangle { height: 16px; background: transparent; }

        // ── Action buttons ─────────────────────────────────────────────────
        HorizontalLayout {
            spacing: 8px;
            alignment: start;

            PrimaryButton {
                icon: Icons.copy;
                label: "Copy";
                clicked => { root.copy(); }
            }

            SecondaryButton {
                icon: root.item.pinned ? Icons.pin-off : Icons.pin;
                label: root.item.pinned ? "Unpin" : "Pin";
                clicked => { root.pin(); }
            }

            DangerButton {
                icon: Icons.trash-2;
                label: "Delete";
                clicked => { root.delete(); }
            }
        }
    }
}

// ---------------------------------------------------------------------------
// Sidebar — collapsible left navigation rail
// 220px (expanded) / 56px (icon-only) with 180ms ease-out animation.
// ---------------------------------------------------------------------------
component Sidebar inherits Rectangle {
    in-out property <int> active-tab: 0;
    in-out property <bool> collapsed: false;
    // Daemon connection state forwarded from RootWindow
    in property <bool> daemon-connected: false;
    in property <string> app-version: "";

    callback tab-changed(int);
    callback toggle-sidebar();

    width: root.collapsed ? 56px : 220px;
    background: Theme.surface-sidebar;
    border-width: 0px;

    animate width { duration: Theme.anim-sidebar; easing: ease-out; }

    VerticalLayout {
        spacing: 0px;

        // ── Toggle button row ─────────────────────────────────────────────
        Rectangle {
            height: 44px;
            background: transparent;

            HorizontalLayout {
                padding-left: root.collapsed ? 12px : 8px;
                padding-right: 8px;
                alignment: root.collapsed ? center : end;

                GhostButton {
                    icon: root.collapsed ? Icons.panel-left-open : Icons.panel-left-close;
                    clicked => { root.toggle-sidebar(); }
                }
            }
        }

        // ── Thin separator ────────────────────────────────────────────────
        Rectangle {
            height: 1px;
            background: Theme.border-subtle;
        }

        // ── Navigation items ──────────────────────────────────────────────
        Rectangle { height: 8px; background: transparent; }

        SidebarTab {
            label: "History";
            icon: Icons.history;
            active: root.active-tab == 0;
            collapsed: root.collapsed;
            activated => {
                root.active-tab = 0;
                root.tab-changed(0);
            }
        }

        SidebarTab {
            label: "Devices";
            icon: Icons.monitor-smartphone;
            active: root.active-tab == 1;
            collapsed: root.collapsed;
            activated => {
                root.active-tab = 1;
                root.tab-changed(1);
            }
        }

        SidebarTab {
            label: "Pair";
            icon: Icons.link-2;
            active: root.active-tab == 2;
            collapsed: root.collapsed;
            activated => {
                root.active-tab = 2;
                root.tab-changed(2);
            }
        }

        SidebarTab {
            label: "Settings";
            icon: Icons.settings-2;
            active: root.active-tab == 3;
            collapsed: root.collapsed;
            activated => {
                root.active-tab = 3;
                root.tab-changed(3);
            }
        }

        // Stretch to push footer down
        Rectangle { vertical-stretch: 1; background: transparent; }

        // ── Status footer ──────────────────────────────────────────────────
        Rectangle {
            height: 1px;
            background: Theme.border-subtle;
        }

        Rectangle {
            height: 40px;
            background: transparent;

            HorizontalLayout {
                padding-left: root.collapsed ? 16px : 12px;
                padding-right: 12px;
                spacing: 8px;
                alignment: center;

                // Daemon status dot
                Rectangle {
                    width: 8px;
                    height: 8px;
                    border-radius: 4px;
                    background: root.daemon-connected ? Theme.color-success : Theme.color-warning;
                }

                if !root.collapsed: Text {
                    text: root.app-version != "" ? root.app-version : "v0.3.0";
                    font-size: 11px;
                    color: Theme.text-tertiary;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
    }

    // Right-edge hairline border
    Rectangle {
        x: parent.width - 1px;
        y: 0;
        width: 1px;
        height: parent.height;
        background: Theme.border-subtle;
    }
}

// ---------------------------------------------------------------------------
// MainWindow — root single-window shell.
// History/Devices/Pair/Settings content area is a placeholder Rectangle per
// tab; Wave 3 tasks replace each with the real view component.
// ---------------------------------------------------------------------------
export component MainWindow inherits Window {
    title: "CopyPaste";
    background: Theme.surface-base;

    preferred-width: 900px;
    preferred-height: 600px;
    min-width: 600px;
    min-height: 400px;

    // ── Public API ──────────────────────────────────────────────────────────
    /// Active sidebar tab: 0=History 1=Devices 2=Pair 3=Settings
    in-out property <int> active-tab: 0;

    /// Whether the left sidebar is collapsed to icon-only rail (56px)
    in-out property <bool> sidebar-collapsed: false;

    /// Current search field value (bound two-way with SearchField)
    in-out property <string> search-query: "";

    /// Daemon connection status — forwarded to sidebar footer dot
    in-out property <bool> daemon-connected: false;

    /// Application version string shown in sidebar footer
    in-out property <string> app-version: "";

    /// Logical screen width in dp/px — set from Rust after window creation.
    /// < 600px → bottom-tab layout (Android); ≥ 600px → sidebar layout (desktop/tablet).
    in property <length> screen-width: 900px;

    /// Fired when the user selects a different sidebar tab.
    callback tab-changed(int);

    /// Fired on every keystroke in the top-bar search field.
    callback search-changed(string);

    /// Fired when the user requests application quit (e.g. ⌘Q).
    callback request-quit();

    // ── Keyboard / palette state (T5.1 + T5.2) ──────────────────────────────
    /// Whether the command palette overlay is open.
    /// When true, all shortcuts are no-ops except Esc.
    in-out property <bool> palette-open: false;

    /// Fired when the user activates a command palette action.
    /// Receives the action id string (e.g. "history", "clear-history").
    callback palette-action(string);

    /// Set to true by ⌘F to request that the search field grabs focus.
    /// The SearchField watches this and resets it after grabbing focus.
    in-out property <bool> search-focused: false;

    // ── History view ────────────────────────────────────────────────────────
    in property <[ClipItem]> history-items: [];
    in property <bool> history-loading: false;
    in property <string> history-error: "";
    in-out property <int> selected-history-index: -1;
    callback item-clicked(int);
    callback item-copy(int);
    callback item-pin(int);
    callback item-delete(int);
    callback fetch-next-page();
    callback open-pair-view();

    // ── Detail panel (T4.2) ─────────────────────────────────────────────────
    /// The clipboard item currently shown in the right-side detail panel.
    in property <ClipItem> detail-item;
    /// Whether the detail panel is open (320px) or closed (0px).
    in-out property <bool> detail-visible: false;
    /// User pressed "Copy" in the detail panel.
    callback detail-copy();
    /// User pressed "Pin/Unpin" in the detail panel.
    callback detail-pin();
    /// User pressed "Delete" in the detail panel.
    callback detail-delete();

    // ── Devices view ────────────────────────────────────────────────────────
    in property <[DeviceEntry]> devices: [];
    callback device-selected(int);
    callback open-pair();
    callback pause-device(int);
    callback unpair-device(int);

    // ── Pair view ───────────────────────────────────────────────────────────
    in-out property <int> pair-mode: 1;
    in property <image> qr-image;
    in property <string> pair-code: "";
    in property <string> pair-status-text: "Waiting for peer…";
    in property <bool> pair-status-is-error: false;
    callback pair-regenerate();
    callback pair-with-code(string);
    callback pair-cancel();
    callback pair-succeeded(string);

    // ── Settings view ───────────────────────────────────────────────────────
    in-out property <int> settings-tab: 0;
    in-out property <int> accent: 0;
    in-out property <bool> compact: false;
    in-out property <bool> vibrancy: true;
    in-out property <bool> launch-at-login: false;
    in-out property <bool> private-mode: false;
    in-out property <int> history-limit: 1000;
    in-out property <bool> sync-enabled: false;
    in-out property <string> sync-url: "";
    in property <string> fingerprint: "";
    in property <[{action: string, keys: string}]> shortcuts: [
        { action: "History",              keys: "⌘1" },
        { action: "Devices",              keys: "⌘2" },
        { action: "Pair",                 keys: "⌘3" },
        { action: "Settings",             keys: "⌘4 / ⌘," },
        { action: "Toggle sidebar",       keys: "⌘\\" },
        { action: "Toggle detail panel",  keys: "⌘⌥\\" },
        { action: "Command palette",      keys: "⌘K" },
        { action: "Search",               keys: "⌘F" },
        { action: "Move selection up",    keys: "↑" },
        { action: "Move selection down",  keys: "↓" },
        { action: "Copy item",            keys: "↵ / ⌘C" },
        { action: "Pin / unpin item",     keys: "⌘P" },
        { action: "Delete item",          keys: "⌫" },
        { action: "New pair",             keys: "⌘N" },
        { action: "Hide window",          keys: "⌘W" },
        { action: "Dismiss / close",      keys: "Esc" },
    ];
    callback save-prefs();
    callback save-app-settings();
    callback clear-history();
    callback reset-pairings();
    callback reset-ui-prefs();
    callback settings-tab-changed(int);

    // ── Layout ──────────────────────────────────────────────────────────────
    // T5.3: screen-width < 600px → Android bottom-tab layout (no sidebar).
    //       screen-width ≥ 600px → desktop sidebar layout.

    // ── Small screen (Android): content area above BottomTabBar ────────────
    if root.screen-width < 600px: VerticalLayout {
        spacing: 0px;

        VerticalLayout {
            spacing: 0px;
            vertical-stretch: 1;

            if root.active-tab == 0: HistoryView {
                vertical-stretch: 1;
                items: root.history-items;
                loading: root.history-loading;
                search-query: root.search-query;
                error-message: root.history-error;
                selected-index <=> root.selected-history-index;
                item-clicked(idx) => { root.item-clicked(idx); }
                item-copy(idx) => { root.item-copy(idx); }
                item-pin(idx) => { root.item-pin(idx); }
                item-delete(idx) => { root.item-delete(idx); }
                search-changed(q) => { root.search-changed(q); }
                fetch-next-page() => { root.fetch-next-page(); }
                open-pair-view() => { root.open-pair-view(); }
            }

            if root.active-tab == 1: DevicesView {
                vertical-stretch: 1;
                devices: root.devices;
                device-selected(idx) => { root.device-selected(idx); }
                open-pair() => { root.open-pair(); }
                pause-device(idx) => { root.pause-device(idx); }
                unpair-device(idx) => { root.unpair-device(idx); }
            }

            if root.active-tab == 2: PairView {
                vertical-stretch: 1;
                pair-mode <=> root.pair-mode;
                qr-image: root.qr-image;
                pair-code: root.pair-code;
                status-text: root.pair-status-text;
                status-is-error: root.pair-status-is-error;
                regenerate() => { root.pair-regenerate(); }
                pair-with-code(code) => { root.pair-with-code(code); }
                cancel() => { root.pair-cancel(); }
                pair-succeeded(fp) => { root.pair-succeeded(fp); }
            }

            if root.active-tab == 3: SettingsView {
                vertical-stretch: 1;
                settings-tab <=> root.settings-tab;
                accent <=> root.accent;
                compact <=> root.compact;
                vibrancy <=> root.vibrancy;
                launch-at-login <=> root.launch-at-login;
                private-mode <=> root.private-mode;
                history-limit <=> root.history-limit;
                sync-enabled <=> root.sync-enabled;
                sync-url <=> root.sync-url;
                fingerprint: root.fingerprint;
                app-version: root.app-version;
                shortcuts: root.shortcuts;
                save-prefs() => { root.save-prefs(); }
                save-app-settings() => { root.save-app-settings(); }
                clear-history() => { root.clear-history(); }
                reset-pairings() => { root.reset-pairings(); }
                reset-ui-prefs() => { root.reset-ui-prefs(); }
                settings-tab-changed(t) => { root.settings-tab-changed(t); }
            }
        }

        BottomTabBar {
            active-tab <=> root.active-tab;
            tab-changed(i) => {
                root.active-tab = i;
                root.tab-changed(i);
                if i != 0 { root.detail-visible = false; }
            }
        }
    }

    // ── Large screen (desktop / tablet ≥ 600px): sidebar layout ────────────
    if root.screen-width >= 600px: HorizontalLayout {
        spacing: 0px;

        sidebar := Sidebar {
            active-tab <=> root.active-tab;
            collapsed <=> root.sidebar-collapsed;
            daemon-connected <=> root.daemon-connected;
            app-version <=> root.app-version;
            tab-changed(i) => {
                root.active-tab = i;
                root.tab-changed(i);
                if i != 0 {
                    root.detail-visible = false;
                }
            }
            toggle-sidebar => {
                root.sidebar-collapsed = !root.sidebar-collapsed;
            }
        }

        VerticalLayout {
            spacing: 0px;
            horizontal-stretch: 1;

            // ── Top bar ────────────────────────────────────────────────────
            Rectangle {
                height: 44px;
                background: Theme.surface-sidebar;

                Rectangle {
                    x: 0;
                    y: parent.height - 1px;
                    width: parent.width;
                    height: 1px;
                    background: Theme.border-subtle;
                }

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    padding-top: 8px;
                    padding-bottom: 8px;
                    spacing: 8px;
                    alignment: center;

                    SearchField {
                        horizontal-stretch: 1;
                        text <=> root.search-query;
                        placeholder: "Search…";
                        edited(q) => { root.search-changed(q); }
                    }
                }
            }

            // ── Content area ──────────────────────────────────────────────
            if root.active-tab == 0: HistoryView {
                vertical-stretch: 1;
                items: root.history-items;
                loading: root.history-loading;
                search-query: root.search-query;
                error-message: root.history-error;
                selected-index <=> root.selected-history-index;
                item-clicked(idx) => { root.item-clicked(idx); }
                item-copy(idx) => { root.item-copy(idx); }
                item-pin(idx) => { root.item-pin(idx); }
                item-delete(idx) => { root.item-delete(idx); }
                search-changed(q) => { root.search-changed(q); }
                fetch-next-page() => { root.fetch-next-page(); }
                open-pair-view() => { root.open-pair-view(); }
            }

            if root.active-tab == 1: DevicesView {
                vertical-stretch: 1;
                devices: root.devices;
                device-selected(idx) => { root.device-selected(idx); }
                open-pair() => { root.open-pair(); }
                pause-device(idx) => { root.pause-device(idx); }
                unpair-device(idx) => { root.unpair-device(idx); }
            }

            if root.active-tab == 2: PairView {
                vertical-stretch: 1;
                pair-mode <=> root.pair-mode;
                qr-image: root.qr-image;
                pair-code: root.pair-code;
                status-text: root.pair-status-text;
                status-is-error: root.pair-status-is-error;
                regenerate() => { root.pair-regenerate(); }
                pair-with-code(code) => { root.pair-with-code(code); }
                cancel() => { root.pair-cancel(); }
                pair-succeeded(fp) => { root.pair-succeeded(fp); }
            }

            if root.active-tab == 3: SettingsView {
                vertical-stretch: 1;
                settings-tab <=> root.settings-tab;
                accent <=> root.accent;
                compact <=> root.compact;
                vibrancy <=> root.vibrancy;
                launch-at-login <=> root.launch-at-login;
                private-mode <=> root.private-mode;
                history-limit <=> root.history-limit;
                sync-enabled <=> root.sync-enabled;
                sync-url <=> root.sync-url;
                fingerprint: root.fingerprint;
                app-version: root.app-version;
                shortcuts: root.shortcuts;
                save-prefs() => { root.save-prefs(); }
                save-app-settings() => { root.save-app-settings(); }
                clear-history() => { root.clear-history(); }
                reset-pairings() => { root.reset-pairings(); }
                reset-ui-prefs() => { root.reset-ui-prefs(); }
                settings-tab-changed(t) => { root.settings-tab-changed(t); }
            }
        }

        ItemDetailPanel {
            detail-visible: root.detail-visible && root.active-tab == 0;
            item: root.detail-item;
            copy => { root.detail-copy(); }
            pin => { root.detail-pin(); }
            delete => { root.detail-delete(); }
        }
    }

    // ── Command palette overlay (T5.1) — must be LAST child so z:100 wins ────
    CommandPalette {
        z: 100;
        open <=> root.palette-open;
        actions: [
            { id: "history",       label: "Go to History",            shortcut: "⌘1" },
            { id: "devices",       label: "Go to Devices",            shortcut: "⌘2" },
            { id: "pair",          label: "Go to Pair",               shortcut: "⌘3" },
            { id: "settings",      label: "Go to Settings",           shortcut: "⌘4" },
            { id: "about",         label: "About CopyPaste",          shortcut: "" },
            { id: "clear-history", label: "Clear clipboard history",  shortcut: "" },
        ];
        action-selected(id) => {
            if id == "history"       { root.active-tab = 0; }
            if id == "devices"       { root.active-tab = 1; }
            if id == "pair"          { root.active-tab = 2; }
            if id == "settings"      { root.active-tab = 3; }
            root.palette-action(id);
        }
        closed => { root.palette-open = false; }
    }

    // ── Global keyboard handler (T5.2) ───────────────────────────────────────
    // Zero-size FocusScope — doesn't affect layout.
    // All shortcuts are no-ops when palette-open is true, except Esc which
    // always dismisses the top-most layer.
    FocusScope {
        width: 0px;
        height: 0px;

        key-pressed(e) => {
            // ── Esc: layered dismiss (palette → detail → search clear) ───────
            if e.text == Key.Escape {
                if root.palette-open {
                    root.palette-open = false;
                    return accept;
                }
                if root.detail-visible {
                    root.detail-visible = false;
                    return accept;
                }
                if root.search-query != "" {
                    root.search-query = "";
                    root.search-changed("");
                    return accept;
                }
                return reject;
            }

            // All remaining shortcuts are blocked when palette is open
            if root.palette-open {
                return reject;
            }

            // ── ⌘ / Ctrl shortcuts ──────────────────────────────────────────
            if e.modifiers.control || e.modifiers.meta {

                // ⌘⌥\ — toggle detail panel (check alt before bare \)
                if e.modifiers.alt && e.text == "\\" {
                    if root.active-tab == 0 {
                        root.detail-visible = !root.detail-visible;
                    }
                    return accept;
                }

                // ⌘\ — toggle sidebar
                if e.text == "\\" {
                    root.sidebar-collapsed = !root.sidebar-collapsed;
                    return accept;
                }

                // ⌘1..4 — tab switch
                if e.text == "1" { root.active-tab = 0; root.tab-changed(0); return accept; }
                if e.text == "2" { root.active-tab = 1; root.tab-changed(1); return accept; }
                if e.text == "3" { root.active-tab = 2; root.tab-changed(2); return accept; }
                if e.text == "4" { root.active-tab = 3; root.tab-changed(3); return accept; }

                // ⌘, — Settings
                if e.text == "," {
                    root.active-tab = 3;
                    root.tab-changed(3);
                    return accept;
                }

                // ⌘K — command palette
                if e.text == "k" || e.text == "K" {
                    root.palette-open = !root.palette-open;
                    return accept;
                }

                // ⌘F — focus search
                if e.text == "f" || e.text == "F" {
                    root.search-focused = true;
                    return accept;
                }

                // ⌘N — navigate to Pair view
                if e.text == "n" || e.text == "N" {
                    root.active-tab = 2;
                    root.tab-changed(2);
                    root.pair-mode = 0;
                    return accept;
                }

                // ⌘W — hide window
                if e.text == "w" || e.text == "W" {
                    root.request-quit();
                    return accept;
                }

                // ⌘P — pin/unpin selected history item (History tab only)
                if (e.text == "p" || e.text == "P") && root.active-tab == 0 {
                    if root.selected-history-index >= 0 {
                        root.item-pin(root.selected-history-index);
                    }
                    return accept;
                }

                // ⌘C — copy selected history item (History tab only)
                if (e.text == "c" || e.text == "C") && root.active-tab == 0 {
                    if root.selected-history-index >= 0 {
                        root.item-copy(root.selected-history-index);
                    }
                    return accept;
                }

                return reject;
            }

            // ── Bare keys (no modifier) ──────────────────────────────────────

            // ↑ — move selection up (History tab only)
            if e.text == Key.UpArrow && root.active-tab == 0 {
                if root.selected-history-index > 0 {
                    root.selected-history-index = root.selected-history-index - 1;
                }
                return accept;
            }

            // ↓ — move selection down (History tab only)
            if e.text == Key.DownArrow && root.active-tab == 0 {
                root.selected-history-index = root.selected-history-index + 1;
                return accept;
            }

            // ↵ — copy selected item (History tab only)
            if e.text == Key.Return && root.active-tab == 0 {
                if root.selected-history-index >= 0 {
                    root.item-copy(root.selected-history-index);
                }
                return accept;
            }

            // ⌫ — delete selected item (History tab only)
            if e.text == Key.Backspace && root.active-tab == 0 {
                if root.selected-history-index >= 0 {
                    root.item-delete(root.selected-history-index);
                }
                return accept;
            }

            return reject;
        }
    }
}
