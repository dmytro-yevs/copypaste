{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CopyPaste",
  "version": "0.5.5",
  "identifier": "com.copypaste.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CopyPaste",
        "width": 980,
        "height": 640,
        "minWidth": 720,
        "minHeight": 460,
        "dragDropEnabled": false,
        "transparent": true,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": true
      },
      {
        "label": "popup",
        "title": "CopyPaste Quick Paste",
        "url": "popup.html",
        "width": 403,
        "height": 624,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
