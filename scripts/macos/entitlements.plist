<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened runtime: tighten by default. JIT and unsigned exec memory are
         disabled because we don't run a JIT (Rust is AOT) and don't load
         arbitrary code at runtime. Disabling these reduces attack surface. -->
    <key>com.apple.security.cs.allow-jit</key>
    <false/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <false/>
    <!-- Library validation is OFF (false here = "do not disable validation"
         = validation stays enabled). Only Apple-signed or same-team-signed
         dylibs may load. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <false/>

    <!-- Networking: relay HTTP client + daemon IPC socket (Unix socket is
         not gated, but server entitlement is required if we ever bind TCP). -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- File access: user-selected files only (e.g. drag-drop, file picker).
         App sandbox is OFF because the clipboard daemon needs full disk
         access semantics (read pasteboard, write history DB outside
         container) and we are not shipping via Mac App Store. -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- ─────────────────────────────────────────────────────────────────
         Keychain ThisDeviceOnly hardening.

         The daemon re-stores the X25519 device-secret key with
         `kSecAttrAccessibleWhenUnlockedThisDeviceOnly` so it never syncs to
         iCloud Keychain (see keychain/mod.rs `set_generic_password_locked_down`).
         Building a `SecAccessControl` with that accessibility requires the
         app to carry a `keychain-access-groups` entitlement.

         DEVELOPER ID SIGNING (release.yml with MACOS_CERTIFICATE_BASE64 set):
           The `$(TeamIdentifierPrefix)` placeholder is resolved by `codesign`
           from the signing certificate's team ID at signing time — no manual
           substitution needed. The entitlement is enforced by the OS and
           ThisDeviceOnly hardening works correctly.

         AD-HOC SIGNING (CI builds without MACOS_CERTIFICATE_BASE64):
           Under ad-hoc signing (`codesign -s -`) there is no team identifier,
           so the OS cannot resolve `$(TeamIdentifierPrefix)`. The entitlement
           is present in the plist but the OS returns errSecMissingEntitlement
           (-34018). The daemon already handles this gracefully: the key stays
           fully usable, only the iCloud-sync suppression is skipped, and a
           warning is logged ("could not migrate device key to ThisDeviceOnly
           accessibility"). This is the same behaviour as before this change —
           the entitlement being in the plist does not break ad-hoc builds.
         ───────────────────────────────────────────────────────────────── -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(TeamIdentifierPrefix)com.copypaste.daemon</string>
    </array>
</dict>
</plist>
