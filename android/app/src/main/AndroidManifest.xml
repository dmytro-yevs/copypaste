<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Network: relay server + Supabase -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Foreground service (API 28+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- MED-12: Clipboard monitoring is not "data sync" per Play policy.
         FGS_SPECIAL_USE is the correct category for niche FGS purposes that
         don't fit dataSync / mediaPlayback / location etc. The Play Store
         requires a property element on the <service> declaring the use case. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Notification permission (runtime, Android 13 / API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Camera: required by the ZXing QR scanner in PairActivity (device pairing).
         Declared explicitly (not just inherited from the embedded scanner library)
         and requested at runtime before launching the scanner. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Camera is optional: the app also pairs by displaying a QR, so don't
         exclude camera-less devices from Play. -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Battery optimization exemption: lets us stay alive for polling.
         Declared here; user is prompted at runtime via ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- SYSTEM_ALERT_WINDOW (draw-over-other-apps / overlay):
         Used by BackgroundCaptureSetupActivity to guide the user through the
         ClipCascade-style overlay trick that lifts Android 10+'s background
         clipboard restriction. The permission itself is declared here so the
         system settings page is reachable; the user grants it manually via
         Settings.ACTION_MANAGE_OVERLAY_PERMISSION (no auto-grant).
         On API < 23 this is granted at install time. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- WorkManager (Supabase background polling + ServiceRestartWorker) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- WorkManager expedited jobs on Android 12+ require FOREGROUND_SERVICE.
         Already declared above. No additional permission needed for expedited jobs. -->

    <!--
        READ_LOGS: signature-level permission used by LogcatCaptureService.
        Cannot be granted by the user via a dialog — must be granted via adb:
          adb shell pm grant com.copypaste.android android.permission.READ_LOGS
        Declaring it here allows checkSelfPermission to return GRANTED after the
        adb grant. Without the declaration the grant command is rejected.
        This permission is NOT requested at runtime and is NOT required for any
        core functionality — it is an opt-in power-user fallback only.
    -->
    <uses-permission android:name="android.permission.READ_LOGS" />

    <application
        android:name=".CopyPasteApp"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.CopyPaste">

        <!-- Main entry point — hosts the bottom-nav shell (Clips / Devices / Settings) -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.CopyPaste">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- First-run onboarding: shown once by MainActivity when permissions are missing -->
        <activity
            android:name=".OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <!-- Kept for deep-link / back-stack compatibility; content now also in bottom nav -->
        <activity
            android:name=".HistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <activity
            android:name=".PairActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <!--
            Portrait-locked ZXing QR scanner used by the pairing flow.

            Declared explicitly (instead of relying on the library-merged
            com.journeyapps.barcodescanner.CaptureActivity) so we can:
              * lock the camera preview to portrait (screenOrientation="portrait")
                — the default scanner rendered the preview rotated 90° on phones
                held upright;
              * pin a known-compatible theme rather than inheriting the app theme
                onto the library activity, which could crash on inflation when the
                scanner opened.
            ScanOptions.setCaptureActivity(PortraitCaptureActivity::class) in
            PairActivity points the scan launcher here.
        -->
        <activity
            android:name=".PortraitCaptureActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:stateNotNeeded="true"
            android:theme="@style/Theme.CopyPaste" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <!-- In-app log viewer, launched from Settings › Diagnostics -->
        <activity
            android:name=".LogViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <!-- In-app Permissions review screen, launched from Settings -->
        <activity
            android:name=".PermissionsSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <!-- Background Capture Setup wizard: overlay + battery + OEM autostart.
             Implements the ClipCascade-style combo for reliable Android 10+
             background clipboard reads. Launched from Settings nav row. -->
        <activity
            android:name=".BackgroundCaptureSetupActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <!--
            Foreground clipboard-monitoring service.

            foregroundServiceType="specialUse" — required on Android 14+ (API 34+).
            "dataSync" was considered but rejected: clipboard monitoring is not a
            data-upload/download operation. Play policy directs clipboard managers
            to use specialUse (which also requires a PROPERTY_SPECIAL_USE_FGS_SUBTYPE
            justification below). Using the wrong type would cause Play Store review
            rejection.

            PROPERTY_SPECIAL_USE_FGS_SUBTYPE is required by Google Play for all
            specialUse foreground services. The value is reviewed by the Play team.
        -->
        <service android:name=".ClipboardService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="false">
            <!-- Required by Play policy for FGS_SPECIAL_USE -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Encrypted clipboard sync between user's paired devices" />
        </service>

        <!-- AccessibilityService: enables background clipboard reading on Android 10+.
             User must manually enable in Settings > Accessibility. OnboardingActivity
             prompts them with ACTION_ACCESSIBILITY_SETTINGS and explains why. -->
        <service
            android:name=".ClipboardAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!--
            BootReceiver: restarts the foreground service after device boot and
            after OEM "quick-boot" / warm-boot cycles.

            Declared exported=true because BOOT_COMPLETED is a system broadcast
            that comes from outside our process (required on API 26+ for implicit
            broadcast exceptions). RECEIVE_BOOT_COMPLETED ensures delivery.

            QUICKBOOT_POWERON variants:
            - android.intent.action.QUICKBOOT_POWERON       generic OEMs / custom ROMs
            - com.android.intent.action.QUICKBOOT_POWERON   Xiaomi/MIUI fast-boot
            - com.htc.intent.action.QUICKBOOT_POWERON       HTC quickboot
            ACTION_LOCKED_BOOT_COMPLETED fires before the credential-encrypted
            storage is unlocked on FBE devices; our service doesn't read the DB
            at boot so it's safe to start early.
        -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <receiver android:name=".CaptureControlReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.copypaste.android.action.PAUSE_CAPTURE" />
                <action android:name="com.copypaste.android.action.RESUME_CAPTURE" />
            </intent-filter>
        </receiver>

        <!--
            LogcatCaptureService: optional power-user background capture path.
            Reads clipboard-change events from the system logcat stream when
            android.permission.READ_LOGS has been granted via adb. This is a
            best-effort fallback — the primary background capture mechanism is
            ClipboardAccessibilityService. See LogcatCaptureService.kt for
            full documentation of capabilities and limitations per Android version.
        -->
        <service
            android:name=".LogcatCaptureService"
            android:exported="false" />

        <!-- WorkManager: Supabase poll worker registered at runtime when backend = SUPABASE.
             ServiceRestartWorker is also registered at runtime by WorkManager. -->
        <provider
            android:name="androidx.work.impl.WorkManagerInitializer"
            android:authorities="${applicationId}.workmanager-init"
            android:exported="false"
            tools:node="remove"
            xmlns:tools="http://schemas.android.com/tools" />

        <!--
            FileProvider for log export (LogExportHelper).

            Shares log files from getExternalFilesDir(null)/logs/ via a
            content:// URI so Share intents work safely with third-party apps.

            The same directory is directly adb-pullable without root:
              adb pull /sdcard/Android/data/com.copypaste.android/files/logs/

            Authority must match LogExportHelper.AUTHORITY =
              "com.copypaste.android.fileprovider"
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
