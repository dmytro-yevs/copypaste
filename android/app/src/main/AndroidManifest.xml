<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Network: relay server + Supabase -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- SyncStatusBadge offline detection queries ConnectivityManager
         (activeNetwork + NET_CAPABILITY_VALIDATED) — requires this normal perm. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service (API 28+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- MED-12: Clipboard monitoring is not "data sync" per Play policy.
         FGS_SPECIAL_USE is the correct category for niche FGS purposes that
         don't fit dataSync / mediaPlayback / location etc. The Play Store
         requires a property element on the <service> declaring the use case. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Notification permission (runtime, Android 13 / API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Camera: required by the ZXing QR scanner in PairActivity (device pairing).
         Declared explicitly (not just inherited from the embedded scanner library)
         and requested at runtime before launching the scanner. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Camera is optional: the app also pairs by displaying a QR, so don't
         exclude camera-less devices from Play. -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Battery optimization exemption: lets us stay alive for polling.
         Declared here; user is prompted at runtime via ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- SYSTEM_ALERT_WINDOW (draw-over-other-apps / overlay):
         Used by BackgroundCaptureSetupActivity to guide the user through the
         ClipCascade-style overlay trick that lifts Android 10+'s background
         clipboard restriction. The permission itself is declared here so the
         system settings page is reachable; the user grants it manually via
         Settings.ACTION_MANAGE_OVERLAY_PERMISSION (no auto-grant).
         On API < 23 this is granted at install time. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- WorkManager (Supabase background polling + ServiceRestartWorker) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- WorkManager expedited jobs on Android 12+ require FOREGROUND_SERVICE.
         Already declared above. No additional permission needed for expedited jobs. -->

    <!--
        READ_LOGS: signature-level permission used by LogcatCaptureService.
        Cannot be granted by the user via a dialog — must be granted via adb:
          adb shell pm grant com.copypaste.android android.permission.READ_LOGS
        Declaring it here allows checkSelfPermission to return GRANTED after the
        adb grant. Without the declaration the grant command is rejected.
        This permission is NOT requested at runtime and is NOT required for any
        core functionality — it is an opt-in power-user fallback only.
    -->
    <!-- ProtectedPermissions: READ_LOGS is a system-only permission, but it is
         declared here solely so that checkSelfPermission returns GRANTED after an
         ADB developer grant (adb shell pm grant … READ_LOGS). It is never requested
         at runtime and is not required for any core functionality. -->
    <uses-permission
        android:name="android.permission.READ_LOGS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:name=".CopyPasteApp"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:theme="@style/Theme.CopyPaste">

        <!-- Main entry point — hosts the bottom-nav shell (Clips / Devices / Settings).
             Theme.CopyPaste.Splash (task 0.10, S12): installSplashScreen() in
             MainActivity.onCreate switches the window to postSplashScreenTheme
             (Theme.CopyPaste) once first-paint is ready. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.CopyPaste.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- First-run onboarding: shown once by MainActivity when permissions are missing -->
        <activity
            android:name=".OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <!-- Kept for deep-link / back-stack compatibility; content now also in bottom nav -->
        <activity
            android:name=".HistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <activity
            android:name=".PairActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.CopyPaste">
            <!--
                cppair:// deep-link: lets external QR scanners (Google Lens, etc.)
                open PairActivity directly when they scan a pairing QR that encodes
                a cppair:// URI.  The URI carries the raw CPPAIR1 payload in the
                query param "p", e.g.:
                  cppair://pair?p=CPPAIR1.<fp>.<token>.<deviceid>.<name>.<host:port>
                PairActivity.onNewIntent extracts the "p" value and feeds it into
                the existing parsePairingQr path — no change to the internal scanner.

                android:exported="true" is required for the system to route the
                intent here; it is safe because the activity has no sensitive data
                of its own — it only initiates an outbound PAKE session.
            -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="cppair" android:host="pair" />
            </intent-filter>
        </activity>

        <!--
            Portrait-locked ZXing QR scanner used by the pairing flow.

            Declared explicitly (instead of relying on the library-merged
            com.journeyapps.barcodescanner.CaptureActivity) so we can:
              * lock the camera preview to portrait (screenOrientation="portrait")
                — the default scanner rendered the preview rotated 90° on phones
                held upright;
              * pin a known-compatible theme rather than inheriting the app theme
                onto the library activity, which could crash on inflation when the
                scanner opened.
            ScanOptions.setCaptureActivity(PortraitCaptureActivity::class) in
            PairActivity points the scan launcher here.
        -->
        <activity
            android:name=".PortraitCaptureActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:stateNotNeeded="true"
            android:theme="@style/Theme.CopyPaste" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <!--
            HB-11: share-target. Lets the user SEND a file (or several) into
            CopyPaste from any app's share sheet ("Share → CopyPaste"). The
            activity reads the EXTRA_STREAM URI(s), captures them as file clipboard
            items via ClipboardService.captureFileClip, and finishes (no UI).

            android:exported="true" is required for the system share sheet to route
            ACTION_SEND / ACTION_SEND_MULTIPLE here. mimeType="*/*" accepts any
            shareable stream (PDF, ZIP, photo, document, …). excludeFromRecents +
            noHistory + Translucent theme keep it invisible and off the recents list.
        -->
        <activity
            android:name=".ShareReceiverActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>

        <!-- In-app log viewer, launched from Settings › Diagnostics -->
        <activity
            android:name=".LogViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <!-- In-app Permissions review screen, launched from Settings -->
        <activity
            android:name=".PermissionsSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <!-- About screen: app version/build + feature list + GitHub link.
             Also surfaced as the "About" tab in MainActivity's bottom nav. -->
        <activity
            android:name=".AboutActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <!-- Background Capture Setup wizard: overlay + battery + OEM autostart.
             Implements the ClipCascade-style combo for reliable Android 10+
             background clipboard reads. Launched from Settings nav row. -->
        <activity
            android:name=".BackgroundCaptureSetupActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <!--
            ClipboardFloatingActivity: transparent focusable overlay used for the
            ClipCascade-technique background clipboard read on Android 10+ (API 29+).

            Launched by LogcatCaptureService when a clipboard-access denial for our
            package is detected in logcat. The Activity adds a TYPE_APPLICATION_OVERLAY
            window, clears FLAG_NOT_FOCUSABLE to gain input focus, waits for the
            OnGlobalLayoutListener callback (the OS lifts the API-29+ clipboard
            restriction at that point), reads getPrimaryClip(), routes through the
            shared capture pipeline, then finishes.

            exported=false       — internal use only; no intent-filter needed
            excludeFromRecents=true — must not appear in the Recents list
            noHistory=true       — must not push onto the back stack
            taskAffinity=""      — detach from the main task so FLAG_ACTIVITY_CLEAR_TASK
                                   does not affect MainActivity's back stack
            theme=FloatingOverlay — translucent/floating/no-dim (invisible to the user)
        -->
        <activity
            android:name=".ClipboardFloatingActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@style/Theme.CopyPaste.FloatingOverlay" />

        <!-- Devices screen: paired P2P peer list + Unpair/Revoke actions.
             Surfaced as the DEVICES tab in MainActivity's bottom nav and as a
             "Devices" nav row in Settings › General. -->
        <activity
            android:name=".DevicesActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <!--
            Foreground clipboard-monitoring service.

            foregroundServiceType="specialUse" — required on Android 14+ (API 34+).
            "dataSync" was considered but rejected: clipboard monitoring is not a
            data-upload/download operation. Play policy directs clipboard managers
            to use specialUse (which also requires a PROPERTY_SPECIAL_USE_FGS_SUBTYPE
            justification below). Using the wrong type would cause Play Store review
            rejection.

            PROPERTY_SPECIAL_USE_FGS_SUBTYPE is required by Google Play for all
            specialUse foreground services. The value is reviewed by the Play team.
        -->
        <service android:name=".ClipboardService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="false">
            <!-- Required by Play policy for FGS_SPECIAL_USE -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Encrypted clipboard sync between user's paired devices" />
        </service>

        <!--
            BootReceiver: restarts the foreground service after device boot and
            after OEM "quick-boot" / warm-boot cycles.

            Declared exported=true because BOOT_COMPLETED is a system broadcast
            that comes from outside our process (required on API 26+ for implicit
            broadcast exceptions). RECEIVE_BOOT_COMPLETED ensures delivery.

            QUICKBOOT_POWERON variants:
            - android.intent.action.QUICKBOOT_POWERON       generic OEMs / custom ROMs
            - com.android.intent.action.QUICKBOOT_POWERON   Xiaomi/MIUI fast-boot
            - com.htc.intent.action.QUICKBOOT_POWERON       HTC quickboot
            ACTION_LOCKED_BOOT_COMPLETED fires before the credential-encrypted
            storage is unlocked on FBE devices; our service doesn't read the DB
            at boot so it's safe to start early.
        -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <receiver android:name=".CaptureControlReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.copypaste.android.action.PAUSE_CAPTURE" />
                <action android:name="com.copypaste.android.action.RESUME_CAPTURE" />
            </intent-filter>
        </receiver>

        <!--
            LogcatCaptureService: optional power-user background capture path.
            Reads clipboard-change events from the system logcat stream when
            android.permission.READ_LOGS has been granted via adb. This is a
            best-effort fallback — the primary background capture mechanism is
            the adb READ_LOGS path. See LogcatCaptureService.kt for
            full documentation of capabilities and limitations per Android version.

            CopyPaste-44rq.4: promoted to foreground service (FGS) with
            foregroundServiceType="specialUse" so Android cannot silently kill
            the logcat-tail loop under memory pressure on API 26+. Play policy
            directs clipboard managers to use specialUse for niche FGS types.
        -->
        <service
            android:name=".LogcatCaptureService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="false">
            <!-- Required by Play policy for FGS_SPECIAL_USE -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Optional power-user logcat-based clipboard change detection via adb-granted READ_LOGS" />
        </service>

        <!-- WorkManager: Supabase poll worker registered at runtime when backend = SUPABASE.
             ServiceRestartWorker is also registered at runtime by WorkManager. -->
        <!-- MissingClass: androidx.work.impl.WorkManagerInitializer is an internal
             WorkManager class that exists at runtime in the work-runtime-ktx AAR.
             This element uses tools:node="remove" to disable WorkManager's default
             content-provider auto-initialisation so we can initialise it manually.
             Lint's MissingClass check is a false positive here — the class is not
             referenced by our code, only by the manifest merge tool. -->
        <provider
            android:name="androidx.work.impl.WorkManagerInitializer"
            android:authorities="${applicationId}.workmanager-init"
            android:exported="false"
            tools:node="remove"
            tools:ignore="MissingClass" />

        <!--
            FileProvider for log export (LogExportHelper).

            Shares log files from getExternalFilesDir(null)/logs/ via a
            content:// URI so Share intents work safely with third-party apps.

            The same directory is directly adb-pullable without root:
              adb pull /sdcard/Android/data/com.copypaste.android/files/logs/

            Authority must match LogExportHelper.AUTHORITY =
              "com.copypaste.android.fileprovider"
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
