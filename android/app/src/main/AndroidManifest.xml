<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- MED-12: Clipboard monitoring is not "data sync" per Play policy.
         FGS_SPECIAL_USE is the correct category for niche FGS purposes that
         don't fit dataSync / mediaPlayback / location etc. The Play Store
         requires a property element on the <service> declaring the use case. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".CopyPasteApp"
        android:label="@string/app_name"
        android:theme="@style/Theme.CopyPaste">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.CopyPaste">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".HistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <activity
            android:name=".PairActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.CopyPaste" />

        <service android:name=".ClipboardService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <!-- Required by Play policy for FGS_SPECIAL_USE: explain the
                 niche purpose so reviewers and the Android Vitals tooling
                 can confirm the category is not abused. -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Encrypted clipboard sync between user's paired devices" />
        </service>

        <receiver android:name=".CaptureControlReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.copypaste.android.action.PAUSE_CAPTURE" />
                <action android:name="com.copypaste.android.action.RESUME_CAPTURE" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
