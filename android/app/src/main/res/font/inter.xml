<?xml version="1.0" encoding="utf-8"?>
<!--
  Bundled Inter font family — DESIGN-SYSTEM-v2 §1 / §10
  Pixel-identical body text across macOS (web) and Android.

  All weight .ttf binaries (400/500/600/700) are committed to git under
  android/app/src/main/res/font/. Weight 700 (inter_bold.ttf) was added in
  android-material3-redesign S1.3 to match STYLEGUIDE §4 Title role (Inter
  700) — see FONT-OFL-NOTICE.txt for provenance/checksum.

  The fontFamily="@font/inter" reference in Type.kt is safe when the .ttf
  files are absent at compile time — the app will crash at font-load time if
  the files are truly missing, so ensure they are present before a release
  build. For development without drop-ins, temporarily revert Type.kt to
  FontFamily.Default (the inter* entries in this XML will be ignored).
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <font
        android:font="@font/inter_regular"
        android:fontWeight="400"
        android:fontStyle="normal"
        app:font="@font/inter_regular"
        app:fontWeight="400"
        app:fontStyle="normal" />

    <font
        android:font="@font/inter_medium"
        android:fontWeight="500"
        android:fontStyle="normal"
        app:font="@font/inter_medium"
        app:fontWeight="500"
        app:fontStyle="normal" />

    <font
        android:font="@font/inter_semibold"
        android:fontWeight="600"
        android:fontStyle="normal"
        app:font="@font/inter_semibold"
        app:fontWeight="600"
        app:fontStyle="normal" />

    <font
        android:font="@font/inter_bold"
        android:fontWeight="700"
        android:fontStyle="normal"
        app:font="@font/inter_bold"
        app:fontWeight="700"
        app:fontStyle="normal" />

</font-family>
