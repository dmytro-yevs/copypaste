<?xml version="1.0" encoding="utf-8"?>
<!--
    List-row pressed-state ripple over a transparent base, using the Darcula
    hover tint (#34373b). Used by View-based list rows.
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#34373B">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#34373B" />
        </shape>
    </item>
</ripple>
