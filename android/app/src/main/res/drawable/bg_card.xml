<?xml version="1.0" encoding="utf-8"?>
<!--
    Rounded elevated card background for View-based layouts (matches the Compose
    CopyPasteCard: ide_panel fill, IdeBorder (#383B42, nearest ramp token — was
    #393B40) hairline border, 12dp radius).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/ide_panel" />
    <corners android:radius="@dimen/radius_card" />
    <stroke
        android:width="1dp"
        android:color="@color/ide_border" />
</shape>
