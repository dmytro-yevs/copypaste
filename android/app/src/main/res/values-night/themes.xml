<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        Night variant — identical to the base theme. The CopyPaste UI is always
        dark (Darcula) regardless of the system day/night setting, so both files
        carry the same dark window background, accent and light system-bar icons.
    -->
    <style name="Theme.CopyPaste" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Accent — Darcula action blue #3574F0 (matches macOS + Compose theme) -->
        <item name="colorPrimary">@color/ide_accent</item>
        <item name="colorPrimaryDark">@color/ide_accent_dark</item>
        <item name="colorAccent">@color/ide_accent</item>

        <!-- Dark window/launch background so there's no white flash before Compose -->
        <item name="android:windowBackground">@color/ide_bg</item>
        <item name="android:colorBackground">@color/ide_bg</item>

        <!-- Edge-to-edge: transparent system bars; Compose applies the insets. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Always-dark UI → light status-bar icons. -->
        <item name="android:windowLightStatusBar">false</item>
        <!-- Use the display cutout (notch / punch-hole) area on the short edges. -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>
</resources>
