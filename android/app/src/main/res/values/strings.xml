    <string name="notif_a11y_warn_title">Background clipboard capture disabled</string>
    <string name="notif_a11y_warn_content">Android 10+ blocks clipboard reads in background. Enable Accessibility to capture clips from other apps.</string>
    <string name="notif_a11y_warn_content_long">Android 10+ (API 29) restricts background clipboard access. CopyPaste can only read clipboard content from other apps when its Accessibility Service is enabled.\n\nTap to open setup and enable it — it reads no screen content and intercepts no input.</string>
    <string name="notif_a11y_warn_action">Enable Accessibility</string>

    <!-- Accessibility service -->
    <string name="accessibility_service_description">Monitors clipboard changes in the background so CopyPaste can sync items even when the app is not in the foreground. Does not read screen content or intercept inputs.</string>

