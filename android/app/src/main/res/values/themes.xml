<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        AppCompat base theme for the AndroidManifest entries. The Compose screens
        draw their own Darcula surfaces via CopyPasteTheme; this theme only governs
        the window background BEFORE Compose composes (the launch/splash frame) and
        the system-bar attributes. We point everything at the dark Darcula tokens
        so launching the app no longer flashes a white (or indigo) frame.

        INSET OWNERSHIP: status-bar / display-cutout WindowInsets handling is owned
        by a separate change. Do NOT add fitsSystemWindows / cutout attributes here
        — keep this purely color + accent so it merges cleanly. Hook left below.
    -->
    <style name="Theme.CopyPaste" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Accent — Graphite Mist §0 cool-grey accent #9DB7DF (c48e default palette) -->
        <item name="colorPrimary">@color/ide_accent</item>
        <item name="colorPrimaryDark">@color/ide_accent_dark</item>
        <item name="colorAccent">@color/ide_accent</item>

        <!--
            Light-mode launch background — EDF2F8 (CloudSilver bg0, CopyPaste-7em1).
            The values-night/ variant stays dark (#07090F); this base theme is only
            loaded in light mode (DayNight parent + no-night suffix). Prevents the
            dark splash-frame flash when the user selects a light palette.
        -->
        <item name="android:windowBackground">@color/ide_bg_light</item>
        <item name="android:colorBackground">@color/ide_bg_light</item>

        <!-- Edge-to-edge: transparent system bars; Compose applies the insets. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Light-mode default → dark status-bar icons (CopyPaste-7em1).
             CopyPasteTheme SideEffect flips this at runtime, but the XML value
             prevents the white-icon flash during the launch frame. -->
        <item name="android:windowLightStatusBar">true</item>
        <!-- Render into the display cutout (notch / punch-hole) area on the short
             edges; combined with the Compose insets this lets the header use
             the full width while never drawing *under* the status bar / notch. -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>

    <!--
        Theme for ClipboardFloatingActivity — the transparent focused overlay Activity
        used by the ClipCascade-technique background clipboard capture path.

        Requirements:
          windowIsTranslucent=true  — window background is see-through (no black flash)
          windowIsFloating=true     — Activity does not fill the screen
          windowBackground=@android:color/transparent — fully transparent
          backgroundDimEnabled=false — do not dim the screen behind it
          windowNoTitle=true        — no title bar decoration

        The Activity must NOT be visible to the user. It finishes in milliseconds; the
        only purpose of the Activity is to host a focusable TYPE_APPLICATION_OVERLAY
        view so getPrimaryClip() is granted clipboard access on API 29+.
    -->
    <style name="Theme.CopyPaste.FloatingOverlay" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>
</resources>
