<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        AppCompat theme retained for the existing AndroidManifest entries that
        reference Theme.MaterialComponents.DayNight.NoActionBar — the Compose
        screens override their own surface colors via CopyPasteTheme.
        We override the application theme here so Compose Activities
        (ComponentActivity, not AppCompatActivity) still get a no-action-bar
        base parent compatible with edge-to-edge layouts.
    -->
    <style name="Theme.CopyPaste" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Brand accent — indigo #5A59E6 -->
        <item name="colorPrimary">@color/copypaste_primary</item>
        <item name="colorPrimaryDark">@color/copypaste_primary_dark</item>
        <item name="colorAccent">@color/copypaste_primary</item>
        <!-- Edge-to-edge: transparent system bars; Compose applies the insets. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- The app is permanently dark (Darcula). Status bar sits on a dark
             background, so use LIGHT icons (windowLightStatusBar = false). -->
        <item name="android:windowLightStatusBar">false</item>
        <!-- Render into the display cutout (notch / punch-hole) area on the short
             edges; combined with the Compose insets below this lets the header use
             the full width while never drawing *under* the status bar / notch. -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>
</resources>
