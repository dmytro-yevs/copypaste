FROM rust:1.75-slim-bookworm

RUN apt-get update && apt-get install -y \
    build-essential \
    pkg-config \
    git \
    curl \
    libssl-dev \
    libsqlcipher-dev \
    libdbus-1-dev \
    && rm -rf /var/lib/apt/lists/*

# Create dev user. On macOS Docker Desktop UID mapping works transparently.
# On Linux hosts: run `docker compose exec -u root dev chown -R 1000:1000 /workspace/target`
# if you see permission errors on the target/ volume.
RUN useradd -m -u 1000 dev
USER dev

WORKDIR /workspace

ENV CARGO_HOME=/home/dev/.cargo
ENV PATH=/home/dev/.cargo/bin:$PATH

CMD ["bash"]
