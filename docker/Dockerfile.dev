FROM rust:1.75-slim-bookworm

RUN apt-get update && apt-get install -y \
    build-essential \
    pkg-config \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -u 1000 dev
USER dev

WORKDIR /workspace

ENV CARGO_HOME=/home/dev/.cargo
ENV PATH=/home/dev/.cargo/bin:$PATH

CMD ["bash"]
